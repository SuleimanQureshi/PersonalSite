  }

  .nb-field-area {
    align-items: flex-start;
  }

  .nb-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--kicker);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
