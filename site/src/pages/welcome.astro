<script>
(function () {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Mood word cycle ────────────────────────────────────────────
  const moods = ['curious', 'caffeinated', 'soldering', 'debugging', 'shipping', 'thinking'];
  let moodIdx = 0;
  const moodEl = document.getElementById('mood-word');
  if (moodEl && !reduced) {
    setInterval(() => {
      moodIdx = (moodIdx + 1) % moods.length;
      moodEl.style.opacity = '0';
      setTimeout(() => {
        moodEl.textContent = moods[moodIdx];
        moodEl.style.opacity = '1';
      }, 200);
    }, 2000);
  }

  // ── Accordion ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.acc-row').forEach((row) => {
    const trigger = row.querySelector<HTMLElement>('.acc-trigger');
    const body    = row.querySelector<HTMLElement>('.acc-body');
    const plus    = row.querySelector<HTMLElement>('.acc-plus');
    const icon    = row.querySelector<HTMLElement>('.acc-icon');
    trigger?.addEventListener('click', () => {
      const isOpen = row.dataset.open === 'true';
      // Close all
      document.querySelectorAll<HTMLElement>('.acc-row').forEach((r) => {
        r.dataset.open = 'false';
        const b = r.querySelector<HTMLElement>('.acc-body');
        const p = r.querySelector<HTMLElement>('.acc-plus');
        const ic = r.querySelector<HTMLElement>('.acc-icon');
        if (b) { b.style.maxHeight = '0'; b.style.opacity = '0'; }
        if (p) p.style.transform = '';
        if (ic) ic.style.transform = '';
      });
      if (!isOpen) {
        row.dataset.open = 'true';
        if (body) { body.style.maxHeight = body.scrollHeight + 'px'; body.style.opacity = '1'; }
        if (plus) plus.style.transform = 'rotate(45deg)';
        if (icon && !reduced) icon.style.transform = 'rotate(-8deg) scale(1.1)';
      }
    });
  });

  // ── Project card flip ──────────────────────────────────────────
  // handled by CSS (no JS needed for the flip itself, hover triggers it)

  // ── Postcard drag ─────────────────────────────────────────────
  const corkboard = document.getElementById('corkboard') as HTMLElement;
  let maxZ = 10;

  corkboard?.querySelectorAll<HTMLElement>('.postcard').forEach((card) => {
    let dragging = false;
    let startX = 0, startY = 0;
    let origLeft = 0, origTop = 0;

    function getPos() {
      const rect = corkboard.getBoundingClientRect();
      const left = parseFloat(card.style.left) / 100 * rect.width;
      const top  = parseFloat(card.style.top)  / 100 * rect.height;
      return { left, top };
    }

    card.addEventListener('mousedown', (e) => {
      if (reduced) return;
      dragging = true;
      maxZ++;
      card.style.zIndex = String(maxZ);
      const pos = getPos();
      startX = e.clientX - pos.left;
      startY = e.clientY - pos.top;
      card.style.cursor = 'grabbing';
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      const rect = corkboard.getBoundingClientRect();
      const newLeft = Math.max(0, Math.min(rect.width - 200, e.clientX - startX));
      const newTop  = Math.max(0, Math.min(rect.height - 180, e.clientY - startY));
      card.style.left = (newLeft / rect.width  * 100).toFixed(2) + '%';
      card.style.top  = (newTop  / rect.height * 100).toFixed(2) + '%';
    });

    document.addEventListener('mouseup', () => {
      if (dragging) {
        dragging = false;
        card.style.cursor = '';
      }
    });

    // Touch support
    card.addEventListener('touchstart', (e) => {
      if (reduced) return;
      const t = e.touches[0];
      dragging = true;
      maxZ++;
      card.style.zIndex = String(maxZ);
      const pos = getPos();
      startX = t.clientX - pos.left;
      startY = t.clientY - pos.top;
      e.preventDefault();
    }, { passive: false });

    card.addEventListener('touchmove', (e) => {
      if (!dragging) return;
      const t = e.touches[0];
      const rect = corkboard.getBoundingClientRect();
      const newLeft = Math.max(0, Math.min(rect.width - 200, t.clientX - startX));
      const newTop  = Math.max(0, Math.min(rect.height - 180, t.clientY - startY));
      card.style.left = (newLeft / rect.width  * 100).toFixed(2) + '%';
      card.style.top  = (newTop  / rect.height * 100).toFixed(2) + '%';
      e.preventDefault();
    }, { passive: false });

    card.addEventListener('touchend', () => { dragging = false; });
  });

  // ── Now tabs ──────────────────────────────────────────────────
  const nowData = [
    { label: 'building', text: "A retrofit autonomous tow truck that's actually about to ship to a real industrial site. First of its kind in Pakistan." },
    { label: 'reading',  text: "Papers on Kolmogorov-Arnold networks. Also: a stack of essays I keep meaning to finish." },
    { label: 'fixing',   text: "Steady-state oscillations in a steering controller. Don't ask. Or do." },
    { label: 'dreaming', text: "A fleet of robots that maintain themselves by listening to their own gearboxes." },
  ];

  const nowLabel = document.getElementById('now-label') as HTMLElement;
  const nowText  = document.getElementById('now-text')  as HTMLElement;

  document.querySelectorAll<HTMLElement>('.now-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.now-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const idx = parseInt(tab.dataset.tab ?? '0', 10);
      if (nowLabel) nowLabel.textContent = nowData[idx].label;
      if (nowText)  nowText.textContent  = nowData[idx].text;
    });
  });

  // ── Contact form ──────────────────────────────────────────────
  const form   = document.getElementById('nb-form')   as HTMLFormElement;
  const thanks = document.getElementById('nb-thanks') as HTMLElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('nb-name') as HTMLInputElement).value.trim();
    const msg  = (document.getElementById('nb-message') as HTMLTextAreaElement).value.trim();
    if (!name || !msg) return;
    // Submit via mailto fallback
    const subject = encodeURIComponent(`Message from ${name}`);
    const body    = encodeURIComponent(msg);
    window.location.href = `mailto:mohammadsulaiman500@gmail.com?subject=${subject}&body=${body}`;
    form.hidden    = true;
    thanks.hidden  = false;
  });

  // ── Notebook date ─────────────────────────────────────────────
  const nbDate = document.getElementById('nb-date');
  if (nbDate) {
    nbDate.textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  // ── Marquee pause on hover ────────────────────────────────────
  const track = document.getElementById('marquee-track');
  if (track) {
    track.addEventListener('mouseenter', () => { track.style.animationPlayState = 'paused'; });
    track.addEventListener('mouseleave', () => { track.style.animationPlayState = ''; });
  }
})();
</script>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --cream:   #f5f0eb;
    --ink:     #1e1520;
    --ink2:    #2e1f2b;
    --rule:    #c4adb5;
    --kicker:  #7a4f5c;
    --tomato:  #7c2840;
    --card:    #fdf9f8;
    --dark:    #180f16;
    --orange-accent: #d4954a;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    position: relative;
  }

  /* Paper grain (fixed overlay) — kept very subtle so text stays readable */
  .grain-overlay {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, #8b6070 1px, transparent 1px);
    background-size: 6px 6px;
    mix-blend-mode: multiply;
    opacity: 0.10;
    pointer-events: none;
    z-index: 100;
  }

  /* ── Nav ───────────────────────────────────────────────────── */
  .nt-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 240, 235, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px dashed var(--rule);
    padding: 14px 40px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-switch {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #4caf72;
    background: #0d100e;
    text-decoration: none;
    border: 1px solid #1e3020;
    padding: 5px 12px;
    white-space: nowrap;
    letter-spacing: 0.06em;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .nav-switch:hover { background: #111; color: #c8ffb8; border-color: #4caf72; }

  .nav-wordmark {
    font-family: 'Caveat', cursive;
    font-size: 26px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    margin-right: auto;
  }

  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--kicker);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--ink); }

  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    padding: 72px 40px 56px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--kicker);
    margin-bottom: 20px;
  }

  .hero-headline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(52px, 7vw, 96px);
    line-height: 1.0;
    color: var(--ink);
    margin-bottom: 24px;
  }
  .hl-italic { font-style: italic; font-weight: 400; }
  .hl-bold   { font-weight: 700;   color: var(--tomato); font-style: normal; }

  .hero-body {
    font-size: 22px;
    color: var(--ink2);
    line-height: 1.5;
  }

  .mood-chip {
    display: inline-block;
    margin-top: 14px;
    background: #fdf0f3;
    border: 1px solid var(--rule);
    padding: 4px 12px;
    font-size: 15px;
    font-family: 'DM Sans', sans-serif;
    color: var(--ink2);
    border-radius: 20px;
  }

  #mood-word {
    font-style: italic;
    color: var(--tomato);
    transition: opacity 0.2s;
  }

  /* Polaroid hero */
  .polaroid-hero {
    position: relative;
    background: #fff;
    padding: 8px 8px 32px;
    box-shadow: 4px 6px 20px rgba(0,0,0,0.18);
    transform: rotate(2.5deg);
    width: 200px;
    flex-shrink: 0;
  }

  .polaroid-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    width: 60px;
    height: 18px;
    background: rgba(180, 130, 145, 0.55);
    border: 1px solid rgba(140, 90, 105, 0.3);
    z-index: 1;
  }

  .polaroid-photo {
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, #c4a0ad 0%, #9e7080 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Caveat', cursive;
    font-size: 14px;
    color: #6e5a40;
    overflow: hidden;
  }

  .polaroid-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .polaroid-photo.photo-fallback::after {
    content: '[ photo of S ]';
    color: #e8cfd5;
  }

  .polaroid-caption {
    font-family: 'Caveat', cursive;
    font-size: 15px;
    color: var(--kicker);
    text-align: center;
    margin-top: 8px;
  }

  /* ── Marquee ───────────────────────────────────────────────── */
  .marquee-strip {
    background: var(--dark);
    overflow: hidden;
    padding: 0;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    padding: 16px 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .marquee-track { animation: marquee 40s linear infinite; }
  }

  .marquee-items {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding-right: 16px;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 22px;
    color: #fff;
  }

  .dot { color: #8a6070; }
  .marquee-accent { color: var(--orange-accent); }

  /* ── Sections ──────────────────────────────────────────────── */
  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 40px;
  }

  .section-shelf {
    background: none;
  }

  .section-header {
    margin-bottom: 48px;
  }

  .sh-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--kicker);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .sh-title {
    font-family: 'Fraunces', Georgia, serif;
