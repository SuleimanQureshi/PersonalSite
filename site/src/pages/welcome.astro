  .nb-input::placeholder,
  .nb-textarea::placeholder { color: #b08898; }

  .nb-submit {
    align-self: flex-start;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 18px;
    background: var(--tomato);
    color: #fff;
    border: none;
    padding: 10px 24px;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .nb-submit:hover { opacity: 0.87; }

  .nb-thanks {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
  }

  .nb-thanks-text {
    font-family: 'Caveat', cursive;
    font-size: 26px;
    color: var(--tomato);
    text-align: center;
  }

  .nb-lines { display: none; }

  /* Contact info */
  .contact-info { padding-top: 16px; }

  .ci-header {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    color: var(--ink2);
    margin-bottom: 24px;
  }

  .contact-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 12px 0;
