  }

  .now-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 26px;
    line-height: 1.5;
    color: #fff;
  }

  /* ── Contact / notebook ────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .notebook {
    display: flex;
    position: relative;
    box-shadow: 3px 5px 18px rgba(0,0,0,0.14);
  }

  .notebook-spine {
    width: 6px;
    background: var(--tomato);
    flex-shrink: 0;
  }

  .notebook-page {
    flex: 1;
    background: var(--card);
    padding: 24px 28px;
    position: relative;
    min-height: 380px;
    background-image: repeating-linear-gradient(
      transparent,
      transparent 32px,
      #d5c0c8 32px,
      #d5c0c8 33px
    );
  }

  .nb-date {
    font-family: 'Caveat', cursive;
    font-size: 14px;
    color: var(--kicker);
    text-align: right;
    margin-bottom: 16px;
  }

  .nb-dear {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .nb-form {
    display: flex;
    flex-direction: column;
