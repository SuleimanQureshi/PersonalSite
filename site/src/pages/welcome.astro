  }

  .sh-note {
    font-family: 'Caveat', cursive;
    font-size: 18px;
    color: var(--kicker);
  }

  /* ── Accordion ─────────────────────────────────────────────── */
  .accordion {
    border-top: 2px solid var(--ink);
  }

  .acc-row {
    border-bottom: 1px solid var(--rule);
  }

  .acc-trigger {
    display: flex;
