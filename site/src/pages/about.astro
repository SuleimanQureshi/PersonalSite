---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Robotics and automation engineer — background, experience, and skills."
>
  <article class="page-wrap">
    <div class="page-header">
      <h1 class="page-title"><span class="mute">// </span>about</h1>
      <p class="page-desc">karachi, sindh, pakistan</p>
    </div>

    <!-- Bio -->
    <div class="prose dark:prose-invert max-w-none section-block reveal">
      <p>
        Robotics and automation engineer with hands-on experience building autonomous systems from
        first principles — from system identification and PID tuning to model predictive control
        and real-time computer vision deployment.
      </p>
      <p>
        Currently leading R&D at <strong>HU-Takhleeq</strong>, where I prototype industry-grade
        solutions including autonomous tow trucks (in collaboration with IMC Toyota) and automated
        inspection systems. My work sits at the intersection of control theory, embedded software,
        and industrial AI — translating research into systems that operate reliably on real hardware.
      </p>
      <p>
        Published researcher across IEEE and CVC 2026, with papers under review at IEEE ICIEA 2026
        and AIM 2026. Consistently top 10% academically (CGPA 3.88/4.0, Dean's List ×4,
        AP Scholar with Distinction).
      </p>
    </div>

    <!-- Experience -->
    <h2 class="section-heading reveal"><span class="mute">// </span>experience</h2>
    <ol class="timeline">
      {([
        {
          role: 'Assistant Manager – R&D',
          org: 'Habib University — HU-Takhleeq',
          period: 'Feb 2025 – Present',
          bullets: [
            'Leading applied robotics and automation R&D — autonomous tow truck, 6-DOF robot arm, industrial automation.',
            'Managing three concurrent industry projects (Dawlance, Toyota).',
            'Corresponding author of accepted paper at CVC 2026, Amsterdam.',
          ],
        },
        {
          role: 'Researcher',
          org: 'Habib University — HU-Takhleeq',
          period: 'Jan – Feb 2025',
          bullets: [
            'Continued FYP R&D: tuned MPPI controller in NAV2 for dynamic path following.',
            'Integrated ROS2 navigation stack with custom hardware drivers.',
          ],
        },
        {
          role: 'Software Engineer Intern',
          org: 'Motive (formerly KeepTruckin)',
          period: 'Jun – Sep 2023 · Remote',
          bullets: [
            'Enhanced vehicle simulation scripts for multiple ECU architectures.',
            'Integrated new features into production CI/CD pipeline.',
          ],
        },
        {
          role: 'Teaching Assistant',
          org: 'Habib University',
          period: 'Jan 2021 – Apr 2024',
          bullets: [
            'DSA, Programming Fundamentals, Signals & Systems, Digital Logic & Design.',
            'Assisted 100+ students across 4 courses.',
          ],
        },
        {
          role: 'Summer Tehqiq Researcher',
          org: 'Habib University',
          period: '2022 – 2024',
          bullets: [
            'Multi-year funded research in automation, robotics, power electronics, and EVs.',
          ],
        },
        {
          role: 'IEEE Chapter Student Lead',
          org: 'Habib University',
          period: 'Mar 2023 – Mar 2024',
          bullets: [
            'Organised tech events, workshops, and seminars to promote engineering engagement.',
          ],
        },
      ] as const).map((item, i) => (
        <li class="timeline-item reveal-left" style={`transition-delay: ${i * 80}ms`}>
          <span class="timeline-dot pulse-dot"></span>
          <div class="timeline-meta">
            <span class="timeline-role">{item.role}</span>
            <span class="timeline-org">{item.org}</span>
          </div>
          <p class="timeline-period">{item.period}</p>
          <ul class="timeline-bullets">
            {item.bullets.map((b) => (
              <li class="timeline-bullet">
                <span class="bullet-dot" aria-hidden="true">›</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>

    <!-- Education -->
    <h2 class="section-heading reveal"><span class="mute">// </span>education</h2>
    <div class="cards-stack">
      <div class="info-card reveal" style="transition-delay: 0ms">
        <div class="card-row">
          <span class="card-primary">B.S. Electrical Engineering</span>
          <span class="card-secondary">Minor: Computer Science</span>
        </div>
        <p class="card-sub">Habib University · Aug 2020 – Dec 2024</p>
        <p class="card-accent">CGPA 3.88 / 4.00 · Dean&rsquo;s List &times;4</p>
      </div>
      <div class="info-card reveal" style="transition-delay: 100ms">
        <span class="card-primary">High School Diploma — Science</span>
        <p class="card-sub">International School of Choueifat – Al Ain · 2007 – 2020</p>
        <p class="card-accent">95 / 100 · AP Scholar with Distinction</p>
      </div>
    </div>

    <!-- Skills -->
    <h2 class="section-heading reveal"><span class="mute">// </span>technical_skills</h2>
    <div class="skills-grid">
      {[
        { category: 'Programming', skills: ['Python', 'C++', 'MATLAB', 'Bash'] },
        { category: 'Robotics & Control', skills: ['ROS2', 'NAV2', 'PID', 'MPC', 'MPPI', 'EtherCAT/SOEM', 'System Identification'] },
        { category: 'AI / Machine Learning', skills: ['PatchCore', 'PyTorch', 'TensorFlow', 'CNNs', 'Anomaly Detection', 'KAN'] },
        { category: 'Simulation & Tools', skills: ['Gazebo', 'Simulink', 'LabVIEW', 'LTspice'] },
        { category: 'Embedded Systems', skills: ['Arduino', 'FPGA', 'TivaC', 'Raspberry Pi', 'Custom PCB Design'] },
      ].map((group, i) => (
        <div class="skill-card reveal" style={`transition-delay: ${i * 70}ms`}>
          <p class="skill-cat">{group.category}</p>
          <div class="skill-tags">
            {group.skills.map((s) => <span class="tag-pill">{s}</span>)}
          </div>
        </div>
      ))}
    </div>

    <!-- Languages -->
    <h2 class="section-heading reveal"><span class="mute">// </span>languages</h2>
    <div class="lang-row reveal" style="transition-delay: 80ms">
      {[
        { lang: 'English', level: 'Native / Bilingual' },
        { lang: 'Urdu', level: 'Native' },
        { lang: 'Arabic', level: 'Elementary' },
        { lang: 'French', level: 'Elementary' },
      ].map(({ lang, level }) => (
        <div class="lang-card">
          <span class="lang-name">{lang}</span>
          <span class="lang-level">{level}</span>
        </div>
      ))}
    </div>

    <!-- Resume -->
    <a href="/Suleiman_Resume_April_2026.pdf" class="btn-primary reveal" style="transition-delay: 100ms">
      cat resume.pdf
    </a>
  </article>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 28px 60px;
  }

  .page-header {
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 20px;
  }

  .page-title {
    font-size: 20px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 6px;
  }

  .page-desc {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0;
    letter-spacing: 0.04em;
  }

  .mute { color: var(--color-mute); }

  .section-block {
    margin-bottom: 40px;
  }

  .section-heading {
    font-size: 13px;
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.06em;
    margin: 36px 0 16px;
    text-transform: uppercase;
  }

  /* Timeline */
  .timeline {
    list-style: none;
    margin: 0 0 40px;
    padding: 0;
    border-left: 1px solid var(--color-line);
    padding-left: 24px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 28px;
  }

  .timeline-dot {
    position: absolute;
    left: -30px;
    top: 4px;
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-ok);
    background: var(--color-bg);
    display: block;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .timeline-role {
    font-size: 13px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
  }

  .timeline-org {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
  }

  .timeline-period {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0 0 8px;
    letter-spacing: 0.04em;
  }

  .timeline-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-bullet {
    display: flex;
    gap: 8px;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .bullet-dot {
    color: var(--color-line);
    flex-shrink: 0;
  }

  /* Education / info cards */
  .cards-stack {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-line);
    margin-bottom: 40px;
  }

  .info-card {
    background: var(--color-panel);
    padding: 16px;
    border: 1px solid var(--color-line);
  }

  .card-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .card-primary {
    font-size: 13px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
  }

  .card-secondary {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
  }

  .card-sub {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0 0 4px;
  }

  .card-accent {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-ok);
    margin: 0;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1px;
    background: var(--color-line);
    margin-bottom: 40px;
  }

  .skill-card {
    background: var(--color-panel);
    padding: 14px;
    border: 1px solid var(--color-line);
  }

  .skill-cat {
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 8px;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  /* Languages */
  .lang-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    background: var(--color-line);
    margin-bottom: 36px;
  }

  .lang-card {
    background: var(--color-panel);
    padding: 10px 16px;
    border: 1px solid var(--color-line);
    font-family: var(--font-mono);
  }

  .lang-name {
    font-size: 12px;
    color: var(--color-text);
    font-weight: 500;
  }

  .lang-level {
    font-size: 10px;
    color: var(--color-mute);
    margin-left: 8px;
  }

  /* Resume button */
  .btn-primary {
    display: inline-block;
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 16px;
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    border: 1px solid var(--color-text);
    transition: opacity 0.1s;
    cursor: pointer;
  }
  .btn-primary:hover { opacity: 0.85; }

  @media (max-width: 640px) {
    .page-wrap { padding: 20px 16px 40px; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
