---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Robotics and automation engineer — background, experience, and skills."
>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="font-heading text-4xl font-semibold text-zinc-900 dark:text-zinc-100 mb-2">About</h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-10">Karachi, Sindh, Pakistan</p>

    <!-- Bio -->
    <div class="prose dark:prose-invert max-w-none mb-14 reveal">
      <p>
        Robotics and automation engineer with hands-on experience building autonomous systems from
        first principles — from system identification and PID tuning to model predictive control
        and real-time computer vision deployment.
      </p>
      <p>
        Currently leading R&D at <strong>HU-Takhleeq</strong>, where I prototype industry-grade
        solutions including autonomous tow trucks (in collaboration with IMC Toyota) and automated
        inspection systems. My work sits at the intersection of control theory, embedded software,
        and industrial AI — translating research into systems that operate reliably on real hardware.
      </p>
      <p>
        Published researcher across IEEE and CVC 2026, with papers under review at IEEE ICIEA 2026
        and AIM 2026. Consistently top 10% academically (CGPA 3.88/4.0, Dean's List ×4,
        AP Scholar with Distinction).
      </p>
    </div>

    <!-- Timeline -->
    <h2 class="font-heading text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6 reveal">Experience</h2>
    <ol class="relative border-l border-zinc-200 dark:border-zinc-700 mb-14 space-y-8">
      {([
        {
          role: 'Assistant Manager – R&D',
          org: 'Habib University — HU-Takhleeq',
          period: 'Feb 2025 – Present',
          bullets: [
            'Leading applied robotics and automation R&D — autonomous tow truck, 6-DOF robot arm, industrial automation.',
            'Managing three concurrent industry projects (Dawlance, Toyota).',
            'Corresponding author of accepted paper at CVC 2026, Amsterdam.',
          ],
        },
        {
          role: 'Researcher',
          org: 'Habib University — HU-Takhleeq',
          period: 'Jan – Feb 2025',
          bullets: [
            'Continued FYP R&D: tuned MPPI controller in NAV2 for dynamic path following.',
            'Integrated ROS2 navigation stack with custom hardware drivers.',
          ],
        },
        {
          role: 'Software Engineer Intern',
          org: 'Motive (formerly KeepTruckin)',
          period: 'Jun – Sep 2023 · Remote',
          bullets: [
            'Enhanced vehicle simulation scripts for multiple ECU architectures.',
            'Integrated new features into production CI/CD pipeline.',
          ],
        },
        {
          role: 'Teaching Assistant',
          org: 'Habib University',
          period: 'Jan 2021 – Apr 2024',
          bullets: [
            'DS&A, Programming Fundamentals, Signals & Systems, Digital Logic & Design.',
            'Assisted 100+ students across 4 courses.',
          ],
        },
        {
          role: 'Summer Tehqiq Researcher',
          org: 'Habib University',
          period: '2022 – 2024',
          bullets: [
            'Multi-year funded research in automation, robotics, power electronics, and EVs.',
          ],
        },
        {
          role: 'IEEE Chapter Lead — CS&E Club',
          org: 'Habib University',
          period: 'Mar 2023 – Mar 2024',
          bullets: [
            'Organised tech events, workshops, and seminars to promote engineering engagement.',
          ],
        },
      ] as const).map((item, i) => (
        <li class="relative ml-6 reveal-left" style={`transition-delay: ${i * 80}ms`}>
          <span class="absolute -left-[1.625rem] top-1.5 h-3 w-3 rounded-full border-2 border-[--color-accent] bg-white dark:bg-zinc-900 pulse-dot"></span>
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5 mb-1">
            <h3 class="font-heading text-lg font-semibold text-zinc-900 dark:text-zinc-100">{item.role}</h3>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">{item.org}</span>
          </div>
          <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-2">{item.period}</p>
          <ul class="space-y-1">
            {item.bullets.map((b) => (
              <li class="flex gap-2 text-sm text-zinc-600 dark:text-zinc-400">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-400 dark:bg-zinc-500"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>

    <!-- Education -->
    <h2 class="font-heading text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6 reveal">Education</h2>
    <div class="space-y-5 mb-14">
      <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 reveal" style="transition-delay: 0ms">
        <div class="flex flex-wrap items-baseline gap-x-3 mb-1">
          <h3 class="font-heading text-lg font-semibold text-zinc-900 dark:text-zinc-100">B.S. Electrical Engineering</h3>
          <span class="text-sm text-zinc-500">Minor: Computer Science</span>
        </div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-1">Habib University · Aug 2020 – Dec 2024</p>
        <p class="text-sm font-medium text-[--color-accent]">CGPA 3.88 / 4.00 · Dean's List ×4</p>
      </div>
      <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 reveal" style="transition-delay: 100ms">
        <h3 class="font-heading text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-1">High School Diploma — Science</h3>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-1">International School of Choueifat – Al Ain · 2007 – 2020</p>
        <p class="text-sm font-medium text-[--color-accent]">95 / 100 · AP Scholar with Distinction</p>
      </div>
    </div>

    <!-- Skills -->
    <h2 class="font-heading text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6 reveal">Technical Skills</h2>
    <div class="grid sm:grid-cols-2 gap-4 mb-14">
      {[
        { category: 'Programming', skills: ['Python', 'C++', 'MATLAB', 'Bash'] },
        { category: 'Robotics & Control', skills: ['ROS2', 'NAV2', 'PID', 'MPC', 'MPPI', 'EtherCAT/SOEM', 'System Identification'] },
        { category: 'AI / Machine Learning', skills: ['PatchCore', 'PyTorch', 'TensorFlow', 'CNNs', 'Anomaly Detection', 'KAN'] },
        { category: 'Simulation & Tools', skills: ['Gazebo', 'Simulink', 'LabVIEW', 'LTspice'] },
        { category: 'Embedded Systems', skills: ['Arduino', 'FPGA', 'TivaC', 'Raspberry Pi', 'Custom PCB Design'] },
      ].map((group, i) => (
        <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 reveal" style={`transition-delay: ${i * 70}ms`}>
          <p class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider mb-2">{group.category}</p>
          <div class="flex flex-wrap gap-1.5">
            {group.skills.map((s) => <span class="tag-pill">{s}</span>)}
          </div>
        </div>
      ))}
    </div>

    <!-- Languages -->
    <h2 class="font-heading text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4 reveal">Languages</h2>
    <div class="flex flex-wrap gap-3 mb-12 reveal" style="transition-delay: 80ms">
      {[
        { lang: 'English', level: 'Native / Bilingual' },
        { lang: 'Urdu', level: 'Native' },
        { lang: 'Arabic', level: 'Elementary' },
        { lang: 'French', level: 'Elementary' },
      ].map(({ lang, level }) => (
        <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 py-2.5 text-sm">
          <span class="font-medium text-zinc-900 dark:text-zinc-100">{lang}</span>
          <span class="ml-2 text-zinc-500 dark:text-zinc-400">{level}</span>
        </div>
      ))}
    </div>

    <!-- Resume download -->
    <a
      href="/Suleiman_Resume_April_2026.pdf"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[--color-accent] text-white text-sm font-medium hover:bg-[--color-accent-hover] transition-colors cursor-pointer reveal"
      style="transition-delay: 100ms"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download Resume (PDF)
    </a>
  </article>
</BaseLayout>

<style>
  .font-heading { font-family: var(--font-heading); }
</style>
