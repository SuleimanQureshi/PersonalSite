  </section>

  <!-- ─── RESEARCH LOG ──────────────────────────────────────────── -->
  <section class="research-log" id="research">
    <div class="log-header">
      <span class="log-title">
        <span class="mute-span">// </span>research_log<span class="mute-span"> [{allPapers.length}]</span>
      </span>
      <span class="log-sort">sort: --date.desc</span>
    </div>

    <div class="log-table">
      <div class="log-cols-header">
        <span>id</span>
        <span>TAG</span>
        <span>year</span>
        <span>title</span>
        <span class="log-keys-col">keys</span>
        <span class="log-chevron-col"></span>
      </div>

      {papersWithMeta.map(({ paper, abstract, venue, bibtex, statusColor, idx }) => (
        <div class="log-entry" data-entry-id={paper.id}>
          <div class="log-row" data-expandable>
            <span class="mute-span">{String(idx + 1).padStart(2, '0')}</span>
            <span class={statusColor}>● {paper.data.status.toUpperCase()}</span>
            <span class="mute-span">{String(paper.data.date).slice(0, 4)}</span>
            <span class="log-title-cell">{paper.data.title}</span>
            <span class="log-keys-col mute-span">{paper.data.tags.slice(0, 3).map((t: string) => `#${t}`).join(' ')}</span>
            <span class="log-chevron">›</span>
          </div>
          <div class="log-expanded" hidden>
            <div class="expanded-left">
              <div class="expanded-eyebrow">Abstract — {venue} {String(paper.data.date).slice(0, 4)}</div>
              <div class="expanded-abstract">{abstract || 'No abstract available.'}</div>
              <div class="expanded-btns">
                <a href={`/research/${paper.id}`} class="btn-open-paper">open paper ↗</a>
                <button class="btn-copy-bib" data-bibtex={bibtex}>copy bib</button>
              </div>
            </div>
            <div class="expanded-right">
              <pre class="expanded-bibtex">{bibtex}</pre>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── FLAGSHIP ─────────────────────────────────────────────── -->
  {pinnedProject && (
    <section class="flagship" id="flagship" onclick="window.location.href='/projects/project-autonomous-ev-tow-truck'" style="cursor:pointer">
      <div class="flagship-header">
        <span><span class="mute-span">// </span>flagship :: <span class="warn-span">ev-tow-01</span></span>
        
      </div>

      <div class="flagship-grid">
        <!-- Left: vehicle schematic -->
        <div class="t-panel schematic-panel">
          <div class="t-header">
            <span>VEHICLE · EV-TOW-01</span><span class="t-unit">retrofit</span>
          </div>
          <div class="schematic-body stripes-dark">
