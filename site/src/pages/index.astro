---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPapers = await getCollection('papers');
const allProjects = await getCollection('projects');

const pinnedProject = allProjects.find((p) => p.id === 'project-autonomous-ev-tow-truck');

const sortedPapers = [...allPapers].sort((a, b) =>
  String(b.data.date).localeCompare(String(a.data.date))
);

function extractAbstract(body: string): string {
  const m = body.match(/## Abstract\n\n?([\s\S]+?)(?:\n---|\n##)/);
  return m?.[1]?.trim() ?? '';
}

function extractVenue(body: string): string {
  const m = body.match(/\|\s*\*\*Venue\*\*\s*\|\s*([^|]+)\|/);
  return m?.[1]?.trim() ?? '—';
}

function generateBibtex(paper: typeof sortedPapers[number], venue: string): string {
  const year = String(paper.data.date).slice(0, 4);
  const firstWord = paper.data.title.split(/\s+/).find(w => w.length > 3) ?? 'work';
  const key = `qureshi${year}${firstWord.toLowerCase().replace(/[^a-z]/g, '')}`;
  const type = paper.data.status === 'published' ? '@inproceedings' : '@article';
  const venueField = venue !== '—' ? `\n  booktitle={${venue}},` : '';
  return `${type}{${key},
  title={${paper.data.title}},
  author={Muhammad Suleiman Qureshi and others},
  year={${year}},${venueField}
}`;
}

const papersWithMeta = sortedPapers.map((paper, i) => {
  const abstract = extractAbstract(paper.body ?? '');
  const venue = extractVenue(paper.body ?? '');
  const bibtex = generateBibtex(paper, venue);
  const statusColor =
    paper.data.status === 'published' || paper.data.status === 'completed' ? 'ok-span' :
    paper.data.status === 'preprint' ? 'blue-span' :
    paper.data.status === 'in-progress' ? 'warn-span' : 'mute-span';
  return { paper, abstract, venue, bibtex, statusColor, idx: i };
});
---

<BaseLayout title="Muhammad Suleiman Qureshi">

  <!-- ─── HERO ──────────────────────────────────────────────────── -->
  <section class="hero-grid">
    <!-- Left: operator profile -->
    <div class="hero-left">
      <p class="breadcrumb"># OPERATOR_PROFILE :: role=R&amp;D_LEAD :: domain=ROBOTICS_AUTOMATION</p>

      <h1 class="name">
        Muhammad<br />Suleiman<br />Qureshi<span class="period">.</span>
      </h1>

      <div class="description">
        <p><span class="gt">&gt;</span> building autonomous systems end-to-end &middot; PCB &rarr; sys-ID &rarr; MPC &rarr; real-time CV.</p>
        <p><span class="gt">&gt;</span> currently leading R&amp;D at <span class="blue">HU-Takhleeq</span> &mdash; Habib University&rsquo;s industry-academia hub.</p>
        <p><span class="gt">&gt;</span> i like systems with tangible impact<span class="cursor-blink"></span></p>
      </div>

      <div class="hero-btns">
        <a href="/contact" class="btn-primary">./contact --open</a>
        <a href="/Suleiman_Resume_April_2026.pdf" class="btn-secondary">cat resume.pdf</a>
      </div>
    </div>

    <!-- Right: 2×2 telemetry panels -->
    <div class="telemetry-grid">
      <!-- VELOCITY -->
      <div class="t-panel" data-metric="velocity">
        <div class="t-header">
          <span>VELOCITY</span><span class="t-unit">m/s</span>
        </div>
        <div class="t-body">
          <div class="t-value" data-value><span class="t-num">0.00</span></div>
          <svg class="sparkline" data-sparkline="velocity" viewBox="0 0 180 36" preserveAspectRatio="none" aria-hidden="true">
            <polyline class="sp-line" points="" fill="none" stroke="var(--color-ok)" stroke-width="1.25"/>
            <line class="sp-guide" x1="0" y1="0" x2="0" y2="36" stroke="var(--color-ok)" stroke-opacity="0.5" stroke-dasharray="2 2" visibility="hidden"/>
            <circle class="sp-dot" cx="0" cy="0" r="2.5" fill="var(--color-ok)" visibility="hidden"/>
            <rect class="sp-tip-box" x="0" y="2" width="48" height="14" fill="var(--color-bg)" stroke="var(--color-line)" stroke-width="0.5" visibility="hidden"/>
            <text class="sp-tip-txt" x="0" y="12" fill="var(--color-ok)" font-size="9" font-family="var(--font-mono)" visibility="hidden"></text>
          </svg>
        </div>
      </div>

      <!-- YAW RATE -->
      <div class="t-panel" data-metric="yaw">
        <div class="t-header">
          <span>YAW RATE</span><span class="t-unit">deg/s</span>
        </div>
        <div class="t-body">
          <div class="t-value" data-value><span class="t-num">0.0</span></div>
          <svg class="sparkline" data-sparkline="yaw" viewBox="0 0 180 36" preserveAspectRatio="none" aria-hidden="true">
            <polyline class="sp-line" points="" fill="none" stroke="var(--color-blue)" stroke-width="1.25"/>
            <line class="sp-guide" x1="0" y1="0" x2="0" y2="36" stroke="var(--color-blue)" stroke-opacity="0.5" stroke-dasharray="2 2" visibility="hidden"/>
            <circle class="sp-dot" cx="0" cy="0" r="2.5" fill="var(--color-blue)" visibility="hidden"/>
            <rect class="sp-tip-box" x="0" y="2" width="48" height="14" fill="var(--color-bg)" stroke="var(--color-line)" stroke-width="0.5" visibility="hidden"/>
            <text class="sp-tip-txt" x="0" y="12" fill="var(--color-blue)" font-size="9" font-family="var(--font-mono)" visibility="hidden"></text>
          </svg>
        </div>
      </div>

      <!-- TRACKING ERR -->
      <div class="t-panel" data-metric="trackerr">
        <div class="t-header">
          <span>TRACKING ERR</span><span class="t-unit">m</span>
        </div>
        <div class="t-body">
          <div class="t-value warn-val" data-value><span class="t-num">0.000</span></div>
          <svg class="sparkline" data-sparkline="trackerr" viewBox="0 0 180 36" preserveAspectRatio="none" aria-hidden="true">
            <polyline class="sp-line" points="" fill="none" stroke="var(--color-warn)" stroke-width="1.25"/>
            <line class="sp-guide" x1="0" y1="0" x2="0" y2="36" stroke="var(--color-warn)" stroke-opacity="0.5" stroke-dasharray="2 2" visibility="hidden"/>
            <circle class="sp-dot" cx="0" cy="0" r="2.5" fill="var(--color-warn)" visibility="hidden"/>
            <rect class="sp-tip-box" x="0" y="2" width="48" height="14" fill="var(--color-bg)" stroke="var(--color-line)" stroke-width="0.5" visibility="hidden"/>
