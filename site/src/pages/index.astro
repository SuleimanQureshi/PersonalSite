  )}

</BaseLayout>

<script>
  // ── PID Simulation ──────────────────────────────────────────────
(function () {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // gains (tunable)
  let Kp = 1.5, Ki = 0.5, Kd = 0.1;

  // plant + controller state
  let velocity = 0;
  let integral = 0;
  let prevError = 0;
  let simTime = 0;

  // response tracking (reset on gain change)
  let peakOvershoot = 0;
  let riseTime: number | null = null;

  const SETPOINT = 1.0;          // normalised target
  const DT = 0.01;               // sim step  (s)
  const STEPS = 8;               // sim steps per display frame
  const HISTORY = 80;
  const W = 180, H = 36;

  const velHist: number[] = Array(HISTORY).fill(0);
  const errHist: number[] = Array(HISTORY).fill(1);

  // ── DOM refs ──────────────────────────────────────────────────
  const $  = (id: string) => document.getElementById(id)!;
  const kpSlider = $('kp-slider') as HTMLInputElement;
  const kiSlider = $('ki-slider') as HTMLInputElement;
  const kdSlider = $('kd-slider') as HTMLInputElement;
  const kpVal = $('kp-val'), kiVal = $('ki-val'), kdVal = $('kd-val');

  const velNum   = document.querySelector('[data-metric="velocity"] .t-num')!;
  const errNum   = document.querySelector('[data-metric="trackerr"] .t-num')!;
  const velPoly  = document.querySelector<SVGPolylineElement>('[data-sparkline="velocity"] .sp-line')!;
  const errPoly  = document.querySelector<SVGPolylineElement>('[data-sparkline="trackerr"] .sp-line')!;

  const termP = $('term-p'), barP = $('bar-p') as HTMLElement;
  const termI = $('term-i'), barI = $('bar-i') as HTMLElement;
  const termD = $('term-d'), barD = $('bar-d') as HTMLElement;
  const termU = $('term-u'), barU = $('bar-u') as HTMLElement;

  // ── Helpers ───────────────────────────────────────────────────
  function resetSim() {
    velocity = 0; integral = 0; prevError = 0; simTime = 0;
    peakOvershoot = 0; riseTime = null;
    velHist.fill(0);
    errHist.fill(1);
  }

  function polyPoints(hist: number[]): string {
    return hist.map((v, i) => {
      const x = (i / (HISTORY - 1)) * W;
      const y = H - Math.min(1, Math.max(0, v)) * H;
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    }).join(' ');
  }

  // ── Slider wiring ─────────────────────────────────────────────
  kpSlider.addEventListener('input', () => { Kp = +kpSlider.value; kpVal.textContent = Kp.toFixed(1); });
  kiSlider.addEventListener('input', () => { Ki = +kiSlider.value; kiVal.textContent = Ki.toFixed(2); });
  kdSlider.addEventListener('input', () => { Kd = +kdSlider.value; kdVal.textContent = Kd.toFixed(2); });
  // ── Sim loop ──────────────────────────────────────────────────
  const FRAME_MS = 1000 / 12;
  let lastFrame = 0;

  function tick(ts: number) {
    requestAnimationFrame(tick);
    if (ts - lastFrame < FRAME_MS) return;
    lastFrame = ts;
    if (reduced) return;

    // Run multiple sim steps per display frame
    let pTerm = 0, iTerm = 0, dTerm = 0, uLast = 0;
    for (let s = 0; s < STEPS; s++) {
      const error = SETPOINT - velocity;
      integral    = Math.max(-8, Math.min(8, integral + error * DT));   // anti-windup
      const deriv = (error - prevError) / DT;
      prevError   = error;

      pTerm = Kp * error;
      iTerm = Ki * integral;
      dTerm = Kd * deriv;
      const u = Math.max(0, Math.min(4, pTerm + iTerm + dTerm));

      pTerm = Kp * error;
      iTerm = Ki * integral;
      dTerm = Kd * deriv;
      uLast = Math.max(0, Math.min(4, pTerm + iTerm + dTerm));

      // First-order lag plant  dv/dt = u − drag·v
      velocity = Math.max(0, velocity + (uLast - 0.85 * velocity) * DT);  
      simTime += DT;

      if (velocity > SETPOINT + 1e-4 && (velocity - SETPOINT) > peakOvershoot)
        peakOvershoot = velocity - SETPOINT;

      if (riseTime === null && velocity >= 0.9 * SETPOINT)
        riseTime = simTime;
    }

    // Push history
    velHist.push(Math.min(1.3, velocity) / 1.3);   // 0–1 for sparkline
    if (velHist.length > HISTORY) velHist.shift();

    const absErr = Math.abs(SETPOINT - velocity);
    errHist.push(Math.min(1, absErr / 0.5));
    if (errHist.length > HISTORY) errHist.shift();

    // Update display values
    velNum.textContent  = (velocity * 3).toFixed(2);          // m/s display
    errNum.textContent  = absErr.toFixed(3);

    // Update sparklines
    velPoly.setAttribute('points', polyPoints(velHist));
    errPoly.setAttribute('points', polyPoints(errHist));

    // Term bars — each bar fills proportionally within ±4 (max u)
    const MAX = 4;
    function setBar(bar: HTMLElement, valEl: Element, val: number) {
      const pct = Math.min(1, Math.abs(val) / MAX) * 100;
      bar.style.width = pct.toFixed(1) + '%';
      valEl.textContent = val.toFixed(2);
    }
    setBar(barP, termP, pTerm);
    setBar(barI, termI, iTerm);
    setBar(barD, termD, dTerm);
    setBar(barU, termU, uLast);
  }
// ── Scrubbable sparklines ──────────────────────────────────────
const scrubCfg = [
  {
    key: 'velocity',
    hist: velHist,
    fmt: (v: number) => (v * 1.3 * 3).toFixed(2),   // normalised → m/s
  },
  {
    key: 'trackerr',
    hist: errHist,
    fmt: (v: number) => (v * 0.5).toFixed(3),        // normalised → m
  },
];

scrubCfg.forEach(({ key, hist, fmt }) => {
  const svg = document.querySelector<SVGSVGElement>(`[data-sparkline="${key}"]`);
  if (!svg) return;
  const guide  = svg.querySelector('.sp-guide')   as SVGLineElement;
  const dot    = svg.querySelector('.sp-dot')     as SVGCircleElement;
  const tipBox = svg.querySelector('.sp-tip-box') as SVGRectElement;
  const tipTxt = svg.querySelector('.sp-tip-txt') as SVGTextElement;

  function showHover(normX: number) {
    const i = Math.round(normX * (hist.length - 1));
    const v = hist[Math.max(0, Math.min(hist.length - 1, i))];
    const vbX = normX * W;
    const vbY = H - Math.min(1, Math.max(0, v)) * H;

    guide.setAttribute('x1', String(vbX)); guide.setAttribute('x2', String(vbX));
    guide.setAttribute('visibility', 'visible');
    dot.setAttribute('cx', String(vbX)); dot.setAttribute('cy', String(vbY));
    dot.setAttribute('visibility', 'visible');
    const tipX = Math.min(vbX + 4, W - 50);
    tipBox.setAttribute('x', String(tipX)); tipBox.setAttribute('visibility', 'visible');
    tipTxt.setAttribute('x', String(tipX + 4));
    tipTxt.textContent = fmt(v);
    tipTxt.setAttribute('visibility', 'visible');
  }

  function hideHover() {
    [guide, dot, tipBox, tipTxt].forEach(el => el?.setAttribute('visibility', 'hidden'));
  }

  svg.addEventListener('mousemove', (e) => {
    const r = svg.getBoundingClientRect();
    showHover(Math.max(0, Math.min(1, (e.clientX - r.left) / r.width)));
  });
  svg.addEventListener('mouseleave', hideHover);
});
  requestAnimationFrame(tick);
})();

  // ── Expandable research rows ──────────────────────────────────────
  (function () {
    let openId: string | null = null;

    document.querySelectorAll<HTMLElement>('.log-entry').forEach((entry) => {
      const row      = entry.querySelector<HTMLElement>('.log-row');
      const expanded = entry.querySelector<HTMLElement>('.log-expanded');
      const chevron  = entry.querySelector<HTMLElement>('.log-chevron');
      const id       = entry.dataset.entryId ?? '';

      row?.addEventListener('click', () => {
        const isOpen = openId === id;

        // Close currently open row
        if (openId) {
          const prev = document.querySelector<HTMLElement>(`[data-entry-id="${openId}"] .log-expanded`);
          const prevChev = document.querySelector<HTMLElement>(`[data-entry-id="${openId}"] .log-chevron`);
          if (prev) prev.hidden = true;
          if (prevChev) prevChev.style.transform = '';
        }

        if (isOpen) {
          openId = null;
        } else {
          openId = id;
          if (expanded) expanded.hidden = false;
          if (chevron) chevron.style.transform = 'rotate(90deg)';
        }
      });

      // Copy bib button
      entry.querySelector<HTMLButtonElement>('.btn-copy-bib')?.addEventListener('click', (e) => {
        e.stopPropagation();
        const bib = (e.currentTarget as HTMLButtonElement).dataset.bibtex ?? '';
        navigator.clipboard.writeText(bib).catch(() => {});
        const btn = e.currentTarget as HTMLButtonElement;
        const orig = btn.textContent;
        btn.textContent = 'copied!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  })();
</script>

