---
// Chooser gate — rendered every visit, no persistence
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Muhammad Suleiman Qureshi</title>
  <meta name="description" content="Portfolio of Muhammad Suleiman Qureshi — robotics, autonomous systems, and embedded engineering." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Caveat:wght@400;600;700&family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" />
</head>
<body>

  <!-- ── TOP BANNER ──────────────────────────────────────────────── -->
  <div class="banner">
    <div class="kicker">─── SELECTION REQUIRED TO CONTINUE ───</div>
    <h1 class="headline">
      Before you visit my site, please tell me &mdash; are you a <em>technical or non-technical visitor?</em>
    </h1>
    <p class="subnote">PICK ONE OF THE TWO SIDES BELOW ↓</p>
  </div>

  <!-- ── SPLIT HALVES ────────────────────────────────────────────── -->
  <div class="split" id="split">

    <!-- TECHNICAL HALF -->
    <div class="half half-tech" id="half-tech" role="button" tabindex="0" aria-label="Enter technical site">
      <!-- Corner ticks -->
      <div class="corner-tick tl"></div>
      <div class="corner-tick br"></div>

      <!-- Waveform decoration (top right) -->
      <svg class="waveform-deco" viewBox="0 0 120 40" aria-hidden="true">
        <polyline points="0,20 8,20 12,8 16,32 20,8 24,32 28,14 32,26 36,20 44,20 48,6 52,34 56,10 60,30 64,16 68,24 72,20 80,20 84,12 88,28 92,16 96,24 100,20 120,20"
          fill="none" stroke="#4caf72" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.55"/>
      </svg>

      <!-- Status row -->
      <div class="tech-status">
        <span class="online-dot">●</span> ONLINE &nbsp;&nbsp; SQ@CONTROL &nbsp;&nbsp; <span id="tech-clock">00:00:00</span> &nbsp;&nbsp; tty1
      </div>

      <!-- Kicker -->
      <div class="tech-kicker">PATH 01 — FOR TECHNICAL VISITORS</div>

      <!-- Top row (mirrors human-top-row) -->
      <div class="tech-top-row">
        <div class="tech-handwritten">the loops, the boards →</div>
        <div class="tech-sticker-inline">
          <svg class="arrow-doodle arrow-doodle-tech" viewBox="0 0 60 40" aria-hidden="true">
            <path d="M5 10 Q 20 35, 45 25" fill="none" stroke="#4caf72" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M40 30 L45 25 L38 23" fill="none" stroke="#4caf72" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <button class="tech-badge" id="tech-badge" aria-label="ships real systems">
            ships<br />real<br />sys ∎
          </button>
        </div>
      </div>

      <!-- Main headline (mirrors human-headline: 2 lines, similar physical size) -->
      <div class="tech-headline">
        <div class="tl-line1">i'm a</div>
        <div class="tl-line2">technical.</div>
      </div>

      <!-- Subcopy -->
      <p class="tech-sub">&gt; show me the control loops, the PCBs,<br />the papers, and the robots.<br /><em>things I&nbsp;<strong>built</strong>, things I&nbsp;<strong>shipped</strong>.</em></p>

      <!-- Terminal preview block -->
      <div class="term-preview">
        <div class="term-line"><span class="t-mute">$</span> ls --papers</div>
        <div class="term-line t-ok">&nbsp;&nbsp;6 peer-reviewed · ICIEA · AIM · CVC · DURS · INMIC</div>
        <div class="term-line"><span class="t-mute">$</span> ls --projects</div>
        <div class="term-line t-ok">&nbsp;&nbsp;ev-tow-01 · forest-walker · defect-eyes · symbolic-listener</div>
        <div class="term-line"><span class="t-mute">$</span> status flagship</div>
        <div class="term-line t-warn">&nbsp;&nbsp;[ACTIVE] ev-tow-01 → final deployment · PK industry</div>
        <div class="term-line"><span class="t-mute">$</span> uptime</div>
        <div class="term-line t-ok">&nbsp;&nbsp;systems nominal &middot; <span id="uptime-tech">00:00:00</span></div>
        <div class="term-line term-cursor-line">
          <span class="t-mute">$</span> whoami --visitor&nbsp;<span class="term-cursor">█</span>
        </div>
      </div>
    </div>

    <!-- NON-TECHNICAL HALF -->
    <div class="half half-human" id="half-human" role="button" tabindex="0" aria-label="Enter non-technical site">

      <!-- Tag bar -->
      <div class="human-tagbar">Issue 06 &middot; The Suleiman Quarterly &middot; karachi &middot; <span id="human-date">2026</span></div>

      <!-- Kicker -->
      <div class="human-kicker">PATH 02 — FOR EVERYONE ELSE</div>

      <!-- Handwritten aside + sticker side by side near the top -->
      <div class="human-top-row">
        <div class="human-handwritten">hey, no jargon here →</div>
        <div class="sticker-inline">
          <svg class="arrow-doodle" viewBox="0 0 60 40" aria-hidden="true">
            <path d="M55 10 Q 40 35, 15 25" fill="none" stroke="#7c2840" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M20 30 L15 25 L22 23" fill="none" stroke="#7c2840" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <button class="sticker" id="sticker" aria-label="built real things">
            built<br />real<br />things ★
          </button>
        </div>
      </div>

      <!-- Main headline -->
      <div class="human-headline">
        <div class="hl-line1">i'm just</div>
        <div class="hl-line2">curious.</div>
      </div>

      <!-- Subcopy -->
      <p class="human-sub">plain English, real projects, zero acronyms.<br /><em>things I&nbsp;<strong>built</strong>, things I&nbsp;<strong>care</strong> about.</em></p>

      <!-- Polaroid row (spread out) -->
      <div class="polaroid-row">
        <div class="polaroid p1">
          <div class="p-img p-img--truck"></div>
          <div class="p-caption">the tow truck</div>
        </div>
        <div class="polaroid p2">
          <div class="p-img p-img--robot"></div>
          <div class="p-caption">forest robot</div>
        </div>
        <div class="polaroid p3">
          <div class="p-img p-img--gear"></div>
          <div class="p-caption">gearbox listener</div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── BOTTOM CTA BAR ───────────────────────────────────────────── -->
  <div class="cta-bar">
    <button class="btn-tech" id="btn-tech">$ enter --tech →</button>
    <span class="or-sep">OR</span>
    <button class="btn-human" id="btn-human">step inside ↗</button>
  </div>

</body>
</html>

<script>
(function () {
  // ── Clock ────────────────────────────────────────────────────────
  function clockTick() {
    const now = new Date();
    const hh = String(now.getHours()).padStart(2, '0');
    const mm = String(now.getMinutes()).padStart(2, '0');
    const ss = String(now.getSeconds()).padStart(2, '0');
    const t = `${hh}:${mm}:${ss}`;
    const el = document.getElementById('tech-clock');
    if (el) el.textContent = t;
  }
  clockTick();
  setInterval(clockTick, 1000);

  // ── Human date ───────────────────────────────────────────────────
  const dateEl = document.getElementById('human-date');
  if (dateEl) {
    const d = new Date();
    dateEl.textContent = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  // ── Uptime ───────────────────────────────────────────────────────
  const start = Date.now();
  function uptimeTick() {
    const s = Math.floor((Date.now() - start) / 1000);
    const fmt = [
      String(Math.floor(s / 3600)).padStart(2, '0'),
      String(Math.floor(s / 60) % 60).padStart(2, '0'),
      String(s % 60).padStart(2, '0'),
    ].join(':');
    const el = document.getElementById('uptime-tech');
    if (el) el.textContent = fmt;
  }
  uptimeTick();
  setInterval(uptimeTick, 1000);

  // ── Sticker spin ─────────────────────────────────────────────────
  let stickerDeg = -8;
  const sticker = document.getElementById('sticker') as HTMLElement;
  sticker?.addEventListener('click', (e) => {
    e.stopPropagation();
    stickerDeg += 360;
    sticker.style.transform = `rotate(${stickerDeg}deg)`;
  });

  // ── Tech badge spin ───────────────────────────────────────────────
  let techBadgeDeg = 8;
  const techBadge = document.getElementById('tech-badge') as HTMLElement;
  techBadge?.addEventListener('click', (e) => {
    e.stopPropagation();
    techBadgeDeg += 360;
    techBadge.style.transform = `rotate(${techBadgeDeg}deg)`;
  });

  // ── Hover expand ─────────────────────────────────────────────────
  const split     = document.getElementById('split') as HTMLElement;
  const halfTech  = document.getElementById('half-tech') as HTMLElement;
  const halfHuman = document.getElementById('half-human') as HTMLElement;
  const btnTech   = document.getElementById('btn-tech') as HTMLButtonElement;
  const btnHuman  = document.getElementById('btn-human') as HTMLButtonElement;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    halfTech.addEventListener('mouseenter', () => {
      split.style.gridTemplateColumns = '62% 38%';
      btnTech.classList.add('cta-active');
      btnHuman.classList.remove('cta-active');
    });
    halfHuman.addEventListener('mouseenter', () => {
      split.style.gridTemplateColumns = '38% 62%';
      btnHuman.classList.add('cta-active');
      btnTech.classList.remove('cta-active');
    });
    split.addEventListener('mouseleave', () => {
      split.style.gridTemplateColumns = '';
      btnTech.classList.remove('cta-active');
      btnHuman.classList.remove('cta-active');
    });
  }

  // ── Navigate ─────────────────────────────────────────────────────
  function commit(chosen: 'tech' | 'human') {
    const chosenEl = chosen === 'tech' ? halfTech  : halfHuman;
    const otherEl  = chosen === 'tech' ? halfHuman : halfTech;
    const dest     = chosen === 'tech' ? '/tech'   : '/welcome';

    if (!reduced) {
      chosenEl.style.transform = 'scale(1.02)';
      otherEl.style.opacity    = '0.15';
      setTimeout(() => { window.location.href = dest; }, 600);
    } else {
      window.location.href = dest;
    }
  }

  halfTech.addEventListener('click',  () => commit('tech'));
  halfHuman.addEventListener('click', () => commit('human'));
  btnTech.addEventListener('click',   () => commit('tech'));
  btnHuman.addEventListener('click',  () => commit('human'));

  halfTech.addEventListener('keydown',  (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); commit('tech');  } });
  halfHuman.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); commit('human'); } });
})();
</script>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    overflow: hidden;
  }

  body {
    display: flex;
    flex-direction: column;
    background: #111;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ── Banner ─────────────────────────────────────────────────── */
  .banner {
    background: #111;
    border-bottom: 1px solid #222;
    padding: 20px 40px 16px;
    flex-shrink: 0;
    text-align: center;
  }

  .kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.32em;
    color: #d4954a;
    margin-bottom: 10px;
  }

  .headline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(20px, 2.5vw, 34px);
    font-weight: 400;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 10px;
  }

  .headline em {
    font-style: italic;
    color: #d4954a;
  }

  .subnote {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #666;
  }

  /* ── Split ──────────────────────────────────────────────────── */
  /* Each half is a flex column with the same padding-top, same gap,
     and same content order. The bottom decoration pushes itself to
     the bottom with margin-top: auto. As long as kicker, top-row,
     headline, and sub have matching heights on each side, the same
     element on the left and right sits at the same y. */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    flex: 1;
    min-height: 0;
    border-bottom: 1px solid #222;
    transition: grid-template-columns 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .half {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: opacity 0.6s ease,
                transform 0.6s ease;
    outline: none;
    padding: 88px 32px 28px;
    user-select: none;
  }

  .half:focus-visible {
    outline: 2px solid #e8a87c;
    outline-offset: -2px;
  }

  /* ── Technical half ─────────────────────────────────────────── */
  .half-tech {
    background: #0d100e;
    border-right: 1px solid #1e2a1e;
  }

  /* Scanlines */
  .half-tech::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      rgba(100, 220, 120, 0.025) 0 1px,
      transparent 1px 3px
    );
    pointer-events: none;
    z-index: 1;
  }

  /* CRT radial glow */
  .half-tech::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 40%, rgba(80, 180, 100, 0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }

  .half-tech .tech-kicker,
  .half-tech .tech-top-row,
  .half-tech .tech-headline,
  .half-tech .tech-sub,
  .half-tech .term-preview { position: relative; z-index: 2; }

  .corner-tick {
    position: absolute !important;
    width: 12px;
    height: 12px;
    z-index: 3;
    pointer-events: none;
  }
  .corner-tick.tl {
    top: 10px; left: 10px;
    border-top: 1px solid #4caf72;
    border-left: 1px solid #4caf72;
  }
  .corner-tick.br {
    bottom: 10px; right: 10px;
    border-bottom: 1px solid #4caf72;
    border-right: 1px solid #4caf72;
  }

  .waveform-deco {
    position: absolute !important;
    top: 14px;
    right: 56px;
    width: 120px;
    height: 40px;
    z-index: 3;
    pointer-events: none;
    opacity: 0.5;
  }

  .tech-status {
    position: absolute !important;
    top: 32px;
    left: 32px;
    right: 32px;
    font-size: 10px;
    color: #4caf72;
    letter-spacing: 0.06em;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
  }
  .online-dot { color: #4caf72; }

  .tech-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #4caf72;
    text-transform: uppercase;
  }

  .tech-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .tech-handwritten {
    font-family: 'Caveat', cursive;
    font-size: 26px;
    color: #4caf72;
    transform: rotate(-2deg);
    display: inline-block;
  }

  .tech-sticker-inline {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .arrow-doodle-tech {
    width: 50px;
    height: 34px;
    opacity: 0.8;
    flex-shrink: 0;
  }

  .tech-badge {
    width: 78px;
    height: 78px;
    background: transparent;
    color: #4caf72;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.35;
    border: 1px solid #4caf72;
    cursor: pointer;
    transform: rotate(8deg);
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
    text-transform: uppercase;
  }

  .tech-badge:focus-visible {
    outline: 2px solid #4caf72;
    outline-offset: 3px;
  }

  /* Matches .human-headline dimensions: same clamp range, same
     line-height, same line count, so both headlines occupy an
     identical vertical block. */
  .tech-headline {
    font-family: 'JetBrains Mono', monospace;
    line-height: 0.95;
    color: #e8f4e3;
    letter-spacing: -2px;
  }

  .tl-line1 {
    font-size: clamp(46px, 5.8vw, 90px);
    font-weight: 400;
  }
  .tl-line2 {
    font-size: clamp(46px, 5.8vw, 90px);
    font-weight: 700;
    color: #4caf72;
  }

  .tech-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #6a9970;
    line-height: 1.6;
  }
  .tech-sub em { font-style: normal; }
  .tech-sub strong { color: #c8ffb8; font-weight: 600; }

  .term-preview {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid #1e3020;
    padding: 12px 14px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    line-height: 1.8;
    max-width: 480px;
    overflow: hidden;
    min-height: 0;
    margin-top: auto;
  }

  .term-line { color: #6a9970; }
  .t-ok   { color: #4caf72; }
  .t-warn { color: #e8a87c; }
  .t-mute { color: #3a5a3c; }

  .term-cursor-line { margin-top: 4px; }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }
    .term-cursor {
      display: inline-block;
      color: #4caf72;
      animation: blink 1s steps(1) infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .term-cursor { color: #4caf72; }
  }

  /* ── Non-technical half ─────────────────────────────────────── */
  .half-human {
    background: #f5f0eb;
    position: relative;
    overflow: hidden;
  }

  /* Paper grain */
  .half-human::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #8b6070 1px, transparent 1px);
    background-size: 6px 6px;
    mix-blend-mode: multiply;
    opacity: 0.18;
    pointer-events: none;
    z-index: 1;
  }

  /* Warm wash */
  .half-human::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 30%, rgba(140, 60, 80, 0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }

  .half-human .human-kicker,
  .half-human .human-top-row,
  .half-human .human-headline,
  .half-human .human-sub,
  .half-human .polaroid-row { position: relative; z-index: 2; }

  .human-tagbar {
    position: absolute !important;
    top: 32px;
    left: 32px;
    right: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #7a4f5c;
    letter-spacing: 0.06em;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
  }

  .human-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #7a4f5c;
    text-transform: uppercase;
  }

  .human-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .human-handwritten {
    font-family: 'Caveat', cursive;
    font-size: 26px;
    color: #7c2840;
    transform: rotate(-2deg);
    display: inline-block;
  }

  .sticker-inline {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .human-headline {
    font-family: 'Fraunces', Georgia, serif;
    line-height: 0.95;
    color: #1e1520;
  }

  .hl-line1 {
    font-size: clamp(50px, 6.2vw, 96px);
    font-weight: 400;
    font-style: italic;
  }
  .hl-line2 {
    font-size: clamp(50px, 6.2vw, 96px);
    font-weight: 700;
    color: #7c2840;
  }

  .human-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #4a3540;
    line-height: 1.6;
  }
  .human-sub em { font-style: normal; }
  .human-sub strong { color: #1e1520; font-weight: 600; }

  /* Polaroids */
  .polaroid-row {
    display: flex;
    gap: 16px;
    align-items: flex-end;
    margin-top: auto;
    padding-top: 12px;
  }

  .polaroid {
    background: #fff;
    padding: 6px 6px 22px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.18);
    flex: 1;
    min-width: 0;
  }

  .p1 { transform: rotate(-5deg); }
  .p2 { transform: rotate(2deg);  }
  .p3 { transform: rotate(-3deg); }

  .p-img {
    width: 100%;
    height: 72px;
    background: #e0d8cc;
  }
  .p-img--truck  { background: linear-gradient(135deg, #c5b99a 0%, #9b8c77 100%); }
  .p-img--robot  { background: linear-gradient(135deg, #a3b89a 0%, #7a9b6e 100%); }
  .p-img--gear   { background: linear-gradient(135deg, #c9b87a 0%, #a08c50 100%); }

  .p-caption {
    font-family: 'Caveat', cursive;
    font-size: 11px;
    color: #4a3540;
    text-align: center;
    margin-top: 4px;
  }

  .arrow-doodle {
    width: 50px;
    height: 34px;
    opacity: 0.8;
    flex-shrink: 0;
  }

  .sticker {
    width: 78px;
    height: 78px;
    border-radius: 50%;
    background: #7c2840;
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.35;
    border: none;
    cursor: pointer;
    transform: rotate(-8deg);
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
