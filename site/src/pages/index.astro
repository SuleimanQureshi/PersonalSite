              <!-- Hitch arm -->
              <rect x="130" y="120" width="50" height="20" fill="none" stroke="var(--color-mute)" stroke-width="1" stroke-dasharray="4,2"/>
              <!-- Wheels -->
              <circle cx="210" cy="185" r="12" fill="none" stroke="var(--color-text)" stroke-width="1.2"/>
              <circle cx="390" cy="185" r="12" fill="none" stroke="var(--color-text)" stroke-width="1.2"/>
              <circle cx="210" cy="75"  r="12" fill="none" stroke="var(--color-text)" stroke-width="1.2"/>
              <circle cx="390" cy="75"  r="12" fill="none" stroke="var(--color-text)" stroke-width="1.2"/>
              <!-- LIDAR -->
              <circle cx="300" cy="67" r="8" fill="var(--color-warn)"/>
              <line x1="300" y1="59" x2="300" y2="20" stroke="var(--color-warn)" stroke-width="0.8" stroke-dasharray="3,2"/>
              <text x="308" y="18" font-size="10" fill="var(--color-warn)" font-family="var(--font-mono)">LIDAR_0</text>
              <!-- IMU -->
              <rect x="290" y="120" width="20" height="20" fill="var(--color-blue)"/>
              <line x1="310" y1="130" x2="370" y2="130" stroke="var(--color-blue)" stroke-width="0.8" stroke-dasharray="3,2"/>
              <text x="374" y="134" font-size="10" fill="var(--color-blue)" font-family="var(--font-mono)">IMU</text>
              <!-- CAM -->
              <rect x="410" y="117" width="14" height="26" fill="var(--color-ok)"/>
              <line x1="424" y1="130" x2="480" y2="130" stroke="var(--color-ok)" stroke-width="0.8" stroke-dasharray="3,2"/>
              <text x="484" y="134" font-size="10" fill="var(--color-ok)" font-family="var(--font-mono)">CAM</text>
              <!-- Captions -->
              <text x="185" y="245" font-size="10" fill="var(--color-mute)" font-family="var(--font-mono)">fig. 01 — sensor layout (top)</text>
              <text x="490" y="245" font-size="10" fill="var(--color-mute)" font-family="var(--font-mono)">scale 1:24</text>
            </svg>
          </div>
        </div>

        <!-- Right: stacked panels -->
        <div class="flagship-right">
          <div class="t-panel">
            <div class="t-header"><span>CONTROL STACK</span></div>
            <div class="t-body control-stack">
              <div><span class="mute-span">│</span> OUTER&nbsp;&nbsp; <span>MPPI (N=1024, H=30)</span></div>
              <div><span class="mute-span">├──</span>&nbsp;&nbsp;&nbsp;&nbsp; COST&nbsp;&nbsp;&nbsp; tracking + obstacle + smoothness</div>
              <div><span class="mute-span">│</span></div>
              <div><span class="mute-span">│</span> INNER&nbsp;&nbsp; <span>PID (v, δ)</span></div>
              <div><span class="mute-span">├──</span>&nbsp;&nbsp;&nbsp;&nbsp; RATE&nbsp;&nbsp;&nbsp; 100 Hz</div>
              <div><span class="mute-span">│</span></div>
              <div><span class="mute-span">│</span> PLANT&nbsp;&nbsp; <span>system-ID&rsquo;d 2DOF bicycle</span></div>
            </div>
          </div>

          <div class="t-panel">
            <div class="t-header"><span>IMPACT</span></div>
            <div class="t-body impact-body">
              Operational and moving towards final deployment. Full-stack: custom PCB, sys-ID, hierarchical control,
              and a real-time perception pipeline. First autonomous retrofit to run on this
              class of vehicle in PK industry.
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<script>
  // ── Live telemetry — requestAnimationFrame, ~12 Hz ────────────────
  (function () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const METRICS: Record<string, { min: number; max: number; decimals: number; fmt: (v: number) => string }> = {
      velocity: { min: 0,   max: 1,   decimals: 2, fmt: v => (v * 3).toFixed(2) },
      yaw:      { min: 0,   max: 1,   decimals: 1, fmt: v => ((v - 0.5) * 24).toFixed(1) },
      trackerr: { min: 0,   max: 1,   decimals: 3, fmt: v => v.toFixed(3) },
    };
    const HISTORY = 80;
    const W = 180, H = 36;
    const FRAME_MS = 1000 / 12;

    const data: Record<string, number[]> = {};
    const targets: Record<string, number> = {};

    Object.keys(METRICS).forEach((k) => {
      data[k] = Array.from({ length: HISTORY }, () => Math.random());
      targets[k] = Math.random();
    });

    // Cache DOM
    const svgEls: Record<string, SVGSVGElement | null> = {};
    const polylines: Record<string, SVGPolylineElement | null> = {};
    const valueEls: Record<string, Element | null> = {};

    Object.keys(METRICS).forEach((k) => {
      const svg = document.querySelector<SVGSVGElement>(`[data-sparkline="${k}"]`);
      svgEls[k] = svg ?? null;
      polylines[k] = svg?.querySelector('.sp-line') ?? null;
      const panel = document.querySelector(`[data-metric="${k}"]`);
      valueEls[k] = panel?.querySelector('.t-num') ?? null;
    });

    // Display value labels also need the original metric range for display
    const DISPLAY_METRICS: Record<string, { min: number; max: number; decimals: number }> = {
      velocity: { min: 0, max: 3,   decimals: 2 },
      yaw:      { min: -5, max: 5,  decimals: 1 },
      trackerr: { min: 0, max: 0.3, decimals: 3 },
    };

    let lastFrame = 0;

    function tick(ts: number) {
      requestAnimationFrame(tick);
      if (ts - lastFrame < FRAME_MS) return;
      lastFrame = ts;

      Object.keys(METRICS).forEach((k) => {
        if (reduced) return; // freeze series on reduced motion

        const current = data[k][data[k].length - 1];
        if (Math.abs(current - targets[k]) < 0.04 || Math.random() < 0.018) {
          targets[k] = Math.random();
        }
        const next = current + (targets[k] - current) * 0.08 + (Math.random() - 0.5) * 0.03;
        data[k].push(Math.min(1, Math.max(0, next)));
        if (data[k].length > HISTORY) data[k].shift();

        // Update sparkline polyline
        if (polylines[k]) {
          const pts = data[k].map((v, i) => {
            const x = (i / (HISTORY - 1)) * W;
            const y = H - v * H;
            return `${x.toFixed(1)},${y.toFixed(1)}`;
          }).join(' ');
          polylines[k]!.setAttribute('points', pts);
        }

        // Update display value
        if (valueEls[k]) {
          const dm = DISPLAY_METRICS[k];
          const raw = data[k][data[k].length - 1];
          const displayed = dm.min + raw * (dm.max - dm.min);
          valueEls[k]!.textContent = displayed.toFixed(dm.decimals);
        }
      });
    }

    requestAnimationFrame(tick);

    // ── Scrubbable sparklines ──────────────────────────────────────
    Object.keys(METRICS).forEach((k) => {
      const svg = svgEls[k];
      if (!svg) return;
      const guide   = svg.querySelector('.sp-guide') as SVGLineElement;
      const dot     = svg.querySelector('.sp-dot') as SVGCircleElement;
      const tipBox  = svg.querySelector('.sp-tip-box') as SVGRectElement;
      const tipTxt  = svg.querySelector('.sp-tip-txt') as SVGTextElement;

      function showHover(normX: number) {
        const i = Math.round(normX * (data[k].length - 1));
        const clamped = Math.max(0, Math.min(data[k].length - 1, i));
        const v = data[k][clamped];
        const vbX = normX * W;
        const vbY = H - v * H;

        guide.setAttribute('x1', String(vbX));
        guide.setAttribute('x2', String(vbX));
        guide.setAttribute('visibility', 'visible');

        dot.setAttribute('cx', String(vbX));
        dot.setAttribute('cy', String(vbY));
        dot.setAttribute('visibility', 'visible');

        const tipX = Math.min(vbX + 4, W - 50);
        tipBox.setAttribute('x', String(tipX));
        tipBox.setAttribute('visibility', 'visible');

        tipTxt.setAttribute('x', String(tipX + 4));
        tipTxt.textContent = METRICS[k].fmt(v);
        tipTxt.setAttribute('visibility', 'visible');
      }

      function hideHover() {
        [guide, dot, tipBox, tipTxt].forEach(el => el?.setAttribute('visibility', 'hidden'));
      }

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect();
        const normX = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
        showHover(normX);
      });

      svg.addEventListener('mouseleave', hideHover);
    });
  })();

  // ── Expandable research rows ──────────────────────────────────────
  (function () {
    let openId: string | null = null;

    document.querySelectorAll<HTMLElement>('.log-entry').forEach((entry) => {
      const row      = entry.querySelector<HTMLElement>('.log-row');
      const expanded = entry.querySelector<HTMLElement>('.log-expanded');
      const chevron  = entry.querySelector<HTMLElement>('.log-chevron');
      const id       = entry.dataset.entryId ?? '';

      row?.addEventListener('click', () => {
        const isOpen = openId === id;

        // Close currently open row
        if (openId) {
          const prev = document.querySelector<HTMLElement>(`[data-entry-id="${openId}"] .log-expanded`);
          const prevChev = document.querySelector<HTMLElement>(`[data-entry-id="${openId}"] .log-chevron`);
          if (prev) prev.hidden = true;
          if (prevChev) prevChev.style.transform = '';
        }

        if (isOpen) {
          openId = null;
        } else {
          openId = id;
          if (expanded) expanded.hidden = false;
          if (chevron) chevron.style.transform = 'rotate(90deg)';
        }
      });

      // Copy bib button
      entry.querySelector<HTMLButtonElement>('.btn-copy-bib')?.addEventListener('click', (e) => {
        e.stopPropagation();
        const bib = (e.currentTarget as HTMLButtonElement).dataset.bibtex ?? '';
        navigator.clipboard.writeText(bib).catch(() => {});
        const btn = e.currentTarget as HTMLButtonElement;
        const orig = btn.textContent;
        btn.textContent = 'copied!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  })();
</script>

<style>
  /* Hero */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 20px;
    padding: 32px 28px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
  }

  .breadcrumb {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .name {
    font-size: 84px;
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    letter-spacing: -2.5px;
    line-height: 1.0;
    color: var(--color-text);
    margin: 0 0 22px;
  }

  .period { color: var(--color-warn); }

  .description {
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .description p { margin: 0; }

  .gt { color: var(--color-text); }
  .blue { color: var(--color-blue); }

  .hero-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 16px;
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    border: 1px solid var(--color-text);
    transition: opacity 0.1s;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 16px;
    background: transparent;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-line);
    transition: border-color 0.1s;
  }
