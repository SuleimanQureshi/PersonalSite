      <div class="stat-value">09</div>
      <div class="stat-sub">/ deployed or live</div>
    </div>
    <div class="stat-cell stat-bordered">
      <div class="stat-label">CGPA</div>
      <div class="stat-value">3.88</div>
      <div class="stat-sub">/ 4.00</div>
    </div>
    <div class="stat-cell stat-bordered">
      <div class="stat-label">DEAN&rsquo;S LIST</div>
      <div class="stat-value">&times;4</div>
      <div class="stat-sub">/ consecutive</div>
