        </div>
        <div class="t-body">
          <div class="sys-status">
            <div><span class="ok-dot">●</span> mppi_node&nbsp;&nbsp;&nbsp;&nbsp; OK</div>
            <div><span class="ok-dot">●</span> ekf_localizer OK</div>
            <div><span class="ok-dot">●</span> can_bridge&nbsp;&nbsp;&nbsp; OK</div>
            <div><span class="warn-dot">●</span> lidar_0&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; OK*</div>
