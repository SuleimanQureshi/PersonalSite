---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Muhammad Suleiman Qureshi — research, collaboration, or opportunities."
>
  <div class="max-w-2xl mx-auto px-6 py-20 text-center">
    <h1 class="font-heading text-4xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Get in Touch</h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-10 leading-relaxed">
      Open to research collaborations, industry partnerships, and interesting problems
      in robotics, autonomous systems, and industrial AI. Based in Karachi — remote-friendly.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
      <a
        href="mailto:mohammadsulaiman500@gmail.com"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-[--color-accent] text-white text-sm font-medium hover:bg-[--color-accent-hover] transition-colors cursor-pointer"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        mohammadsulaiman500@gmail.com
      </a>
      <a
        href="https://www.linkedin.com/in/msuleimanqureshi"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <div class="rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-6 text-left max-w-sm mx-auto">
      <p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Details</p>
      <ul class="space-y-2 text-sm text-zinc-600 dark:text-zinc-400">
        <li><span class="text-zinc-400 dark:text-zinc-500 mr-2">Location</span>Karachi, Sindh, Pakistan</li>
        <li><span class="text-zinc-400 dark:text-zinc-500 mr-2">Phone</span>+92 320 2064404</li>
        <li><span class="text-zinc-400 dark:text-zinc-500 mr-2">Timezone</span>PKT (UTC+5)</li>
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .font-heading { font-family: var(--font-heading); }
</style>
