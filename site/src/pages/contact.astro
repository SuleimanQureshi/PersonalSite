---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Muhammad Suleiman Qureshi — research, collaboration, or opportunities."
>
  <div class="page-wrap">
    <div class="page-header">
      <h1 class="page-title"><span class="mute">// </span>contact</h1>
      <p class="page-desc">Open to research collaborations, industry partnerships, and interesting problems in robotics and autonomous systems.</p>
    </div>

    <div class="contact-grid">
      <!-- Primary actions -->
      <div class="contact-actions">
        <a href="mailto:mohammadsulaiman500@gmail.com" class="contact-btn contact-btn--primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          mohammadsulaiman500@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/msuleimanqureshi" target="_blank" rel="noopener" class="contact-btn contact-btn--secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>

      <!-- Details panel -->
      <div class="details-panel">
        <div class="details-header">OPERATOR_DETAILS</div>
        <div class="details-body">
          <div class="detail-row">
            <span class="detail-key">LOCATION</span>
            <span class="detail-val">Karachi, Sindh, Pakistan</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">PHONE</span>
            <span class="detail-val">+92 320 2064404</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">TIMEZONE</span>
            <span class="detail-val">PKT (UTC+5)</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">REMOTE</span>
            <span class="detail-val ok-span">● available</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 32px 28px 60px;
    max-width: 700px;
  }

  .page-header {
    margin-bottom: 36px;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 20px;
  }

  .page-title {
    font-size: 20px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 8px;
  }

  .mute { color: var(--color-mute); }

  .page-desc {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0;
    line-height: 1.6;
    max-width: 500px;
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: opacity 0.1s, border-color 0.1s;
  }

  .contact-btn--primary {
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }
  .contact-btn--primary:hover { opacity: 0.85; }

  .contact-btn--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-line);
  }
  .contact-btn--secondary:hover { border-color: var(--color-mute); }

  /* Details panel */
  .details-panel {
    border: 1px solid var(--color-line);
    background: var(--color-panel);
    max-width: 360px;
  }

  .details-header {
    padding: 8px 14px;
    border-bottom: 1px solid var(--color-line);
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .details-body {
    padding: 4px 0;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 7px 14px;
    border-bottom: 1px solid var(--color-line);
    font-family: var(--font-mono);
  }
  .detail-row:last-child { border-bottom: none; }

  .detail-key {
    font-size: 10px;
    color: var(--color-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .detail-val {
    font-size: 11px;
    color: var(--color-text);
  }

  .ok-span { color: var(--color-ok); }

  @media (max-width: 640px) {
    .page-wrap { padding: 20px 16px 40px; }
  }
</style>
