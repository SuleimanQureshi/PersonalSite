---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperCard from '../components/PaperCard.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort((a, b) =>
  String(b.data.date).localeCompare(String(a.data.date))
);

function getSummary(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const match = body.match(/^\s*>\s*(.+)/m);
  return match?.[1]?.trim();
}

const statusOrder: Record<string, number> = {
  published: 0,
  completed: 0,
  preprint: 1,
  'in-progress': 2,
  archived: 3,
};

const sorted = [...papers].sort(
  (a, b) => (statusOrder[a.data.status] ?? 9) - (statusOrder[b.data.status] ?? 9)
);

function getVenue(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/\|\s*\*\*Venue\*\*\s*\|\s*([^|]+)\|/);
  return m?.[1]?.trim();
}
---

<BaseLayout
  title="Research"
  description="Papers and research by Muhammad Suleiman Qureshi in robotics, control systems, and computer vision."
>
  <div class="page-wrap">
    <div class="page-header">
      <h1 class="page-title"><span class="mute">// </span>research</h1>
      <p class="page-desc">Published and ongoing work spanning autonomous systems, control theory, and industrial CV.</p>
    </div>

    <div class="cards-grid">
      {sorted.map((paper) => (
        <PaperCard
          title={paper.data.title}
          slug={paper.id}
          status={paper.data.status}
          date={String(paper.data.date)}
          tags={paper.data.tags}
          summary={getSummary(paper.body)}
          venue={getVenue(paper.body)}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 32px 28px;
  }

  .page-header {
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 20px;
  }

  .page-title {
    font-size: 20px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 6px;
  }

  .mute { color: var(--color-mute); }

  .page-desc {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0;
    line-height: 1.5;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--color-line);
  }

  @media (max-width: 640px) {
    .page-wrap { padding: 20px 16px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
