---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) =>
  String(b.data.date).localeCompare(String(a.data.date))
);

function getSummary(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const match = body.match(/^\s*>\s*(.+)/m);
  return match?.[1]?.trim();
}

const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();

function getCollaborator(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/\|\s*\*\*Collaborator\*\*\s*\|\s*([^|]+)\|/);
  return m?.[1]?.trim();
}
---

<BaseLayout
  title="Projects"
  description="Engineering projects by Muhammad Suleiman Qureshi — autonomous systems, robotics, and computer vision."
>
  <div class="page-wrap">
    <div class="page-header">
      <h1 class="page-title"><span class="mute">// </span>projects</h1>
      <p class="page-desc">From autonomous tow trucks to robotic arms — hardware, software, and everything in between.</p>
    </div>

    <!-- Tag filter -->
    <div class="tag-filter" id="tag-filter">
      <button data-tag="" class="tag-btn active">ALL</button>
      {allTags.map((tag) => (
        <button data-tag={tag} class="tag-btn">{tag}</button>
      ))}
    </div>

    <div class="cards-grid" id="project-grid">
      {projects.map((project) => (
        <div class="project-item" data-tags={project.data.tags.join(',')}>
          <ProjectCard
            title={project.data.title}
            slug={project.id}
            status={project.data.status}
            date={String(project.data.date)}
            tags={project.data.tags}
            summary={getSummary(project.body)}
            collaborator={getCollaborator(project.body)}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 32px 28px;
  }

  .page-header {
    margin-bottom: 24px;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 20px;
  }

  .page-title {
    font-size: 20px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 6px;
  }

  .mute { color: var(--color-mute); }

  .page-desc {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0;
    line-height: 1.5;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .tag-btn {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid var(--color-line);
    color: var(--color-mute);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.1s, color 0.1s, background 0.1s;
  }

  .tag-btn:hover:not(.active) {
    border-color: var(--color-mute);
    color: var(--color-text);
  }

  .tag-btn.active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: var(--color-bg);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--color-line);
  }

  .project-item { background: var(--color-bg); }
  .project-item.hidden { display: none; }

  @media (max-width: 640px) {
    .page-wrap { padding: 20px 16px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLDivElement>('.project-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      items.forEach((item) => {
        const tags = (item.dataset.tags ?? '').split(',');
        item.classList.toggle('hidden', !(!tag || tags.includes(tag)));
      });
    });
  });
</script>
