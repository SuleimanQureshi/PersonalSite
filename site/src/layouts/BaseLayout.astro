---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Robotics & Automation Engineer — ROS2, MPPI, Computer Vision, Embedded Systems',
  ogImage = '/og-default.png',
} = Astro.props;

const currentPath = Astro.url.pathname;
const buildTime = new Date().toISOString();

function navClass(href: string): string {
  const active = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
  return active ? 'topbar-link topbar-link--active' : 'topbar-link';
}

const siteTitle = title === 'Muhammad Suleiman Qureshi'
  ? title
  : `${title} — Muhammad Suleiman Qureshi`;
---
<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="Muhammad Suleiman Qureshi" />

  <!-- OG -->
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />

  <title>{siteTitle}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" />
</head>
<body class="min-h-screen">

  <!-- CRT scanlines overlay (only visible in crt theme) -->
  <div id="crt-overlay" aria-hidden="true"></div>

  <!-- Scroll-progress hairline -->
  <div class="scroll-hairline" aria-hidden="true">
    <div class="scroll-hairline-fill" id="scroll-fill"></div>
  </div>

  <header id="top" data-built={buildTime} class="topbar">
    <div class="topbar-left">
      <a href="/" style="text-decoration:none;color:inherit"><strong>SQ</strong> <span class="mute">/ control</span></a>
      <span class="divider">│</span>
      <span class="online">● ONLINE</span>
      <span class="divider">│</span>
      <span class="mute">uptime <span id="uptime-val">00:00:00</span></span>
      <span class="divider">│</span>
      <span class="mute">scroll <span id="scroll-pct">0</span>%</span>
      <span class="divider">│</span>
      <span class="mute">last key <span class="kbd-chip" id="last-key-chip">—</span></span>
    </div>
    <nav class="topbar-nav">
      <a href="/"         class={navClass('/')}>OVERVIEW</a>
      <a href="/research" class={navClass('/research')}>RESEARCH</a>
      <a href="/projects" class={navClass('/projects')}>PROJECTS</a>
      <a href="/about"    class={navClass('/about')}>ABOUT</a>
      <a href="/contact"  class={navClass('/contact')}>CONTACT</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <span>SQ@ 2026 &middot; karachi, pk</span>
    <span>$ uptime &amp; thanks &mdash; shell closed</span>
  </footer>

  <!-- Command palette -->
  <div id="palette-overlay" class="palette-overlay" hidden>
    <div class="palette-box">
      <div class="palette-header">
        <span class="palette-prompt">$</span>
        <input
          id="palette-input"
          class="palette-input"
          type="text"
          autocomplete="off"
          spellcheck="false"
          placeholder="type a command — e.g. 'go research', 'theme light', 'help'"
        />
        <span class="palette-esc">esc</span>
      </div>
      <div class="palette-results" id="palette-results"></div>
    </div>
  </div>

  <!-- Help HUD -->
  <div id="help-overlay" class="help-overlay" hidden>
    <div class="help-box">
      <div class="help-title"><span>?</span> keyboard shortcuts</div>
      <table class="help-table">
        <tbody>
          <tr>
            <td><kbd class="kbd-chip">/</kbd> <kbd class="kbd-chip">:</kbd></td>
            <td>open command palette</td>
          </tr>
          <tr>
            <td><kbd class="kbd-chip">?</kbd></td>
            <td>toggle this help HUD</td>
          </tr>
          <tr>
            <td><kbd class="kbd-chip">Esc</kbd></td>
            <td>close overlays</td>
          </tr>
          <tr>
            <td><kbd class="kbd-chip">g</kbd> <kbd class="kbd-chip">r</kbd></td>
            <td>go to research log</td>
          </tr>
          <tr>
            <td><kbd class="kbd-chip">g</kbd> <kbd class="kbd-chip">f</kbd></td>
            <td>go to flagship project</td>
          </tr>
          <tr>
            <td><kbd class="kbd-chip">g</kbd> <kbd class="kbd-chip">t</kbd></td>
            <td>go to top</td>
          </tr>
        </tbody>
      </table>
      <div class="help-footer">$ esc to close</div>
    </div>
  </div>

  <script>
    // ── Theme ────────────────────────────────────────────────────────
    (function () {
      const saved = localStorage.getItem('sq.theme') as 'dark' | 'light' | 'crt' | null;
      if (saved && saved !== 'dark') {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();

    function setTheme(t: 'dark' | 'light' | 'crt') {
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('sq.theme', t);
    }

    // ── Uptime (from page mount) ──────────────────────────────────────
    (function () {
      const val = document.getElementById('uptime-val');
      if (!val) return;
      const start = Date.now();
      function fmt(s: number) {
        return [
          String(Math.floor(s / 3600)).padStart(2, '0'),
          String(Math.floor(s / 60) % 60).padStart(2, '0'),
          String(s % 60).padStart(2, '0'),
        ].join(':');
      }
      function tick() {
        val!.textContent = fmt(Math.floor((Date.now() - start) / 1000));
      }
      tick();
      setInterval(tick, 1000);
    })();

    // ── Scroll progress ───────────────────────────────────────────────
    (function () {
      const fill = document.getElementById('scroll-fill');
      const pct  = document.getElementById('scroll-pct');
      function onScroll() {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        if (fill) fill.style.width = `${ratio * 100}%`;
        if (pct) pct.textContent = String(Math.round(ratio * 100));
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();

    // ── Last key ──────────────────────────────────────────────────────
    (function () {
      const chip = document.getElementById('last-key-chip');
      if (!chip) return;
      const RECORD = new Set(['/', ':', '?', 'Enter', 'Escape', ' ']);
      document.addEventListener('keydown', (e) => {
        const t = e.target as HTMLElement;
        if (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA') return;
        const k = e.key;
        if (k.length === 1 || RECORD.has(k)) {
          chip.textContent = k === ' ' ? '␣' : k;
        }
      });
    })();

    // ── Command palette ───────────────────────────────────────────────
    const COMMANDS = [
      { key: 'go research',  desc: 'jump to research log',   run: () => document.getElementById('research')?.scrollIntoView({ behavior: 'smooth' }) },
      { key: 'go flagship',  desc: 'jump to flagship project', run: () => document.getElementById('flagship')?.scrollIntoView({ behavior: 'smooth' }) },
      { key: 'go top',       desc: 'jump to top',             run: () => window.scrollTo({ top: 0, behavior: 'smooth' }) },
      { key: 'open contact', desc: 'navigate to /contact',    run: () => { window.location.href = '/contact'; } },
      { key: 'cat resume',   desc: 'open resume.pdf',         run: () => window.open('/Suleiman_Resume_April_2026.pdf', '_blank') },
      { key: 'theme dark',   desc: 'default theme',           run: () => setTheme('dark') },
      { key: 'theme light',  desc: 'paper / light mode',      run: () => setTheme('light') },
      { key: 'theme crt',    desc: 'phosphor / scanline mode', run: () => setTheme('crt') },
      { key: 'help',         desc: 'show keyboard shortcuts',  run: () => openHelp() },
    ];

    const paletteOverlay = document.getElementById('palette-overlay') as HTMLElement;
    const paletteInput   = document.getElementById('palette-input') as HTMLInputElement;
    const paletteResults = document.getElementById('palette-results') as HTMLElement;

    function renderPalette(q: string) {
      const matches = q
        ? COMMANDS.filter(c => c.key.includes(q.toLowerCase()) || c.desc.includes(q.toLowerCase()))
        : COMMANDS;
      if (!matches.length) {
        paletteResults.innerHTML = `<div class="palette-empty">no matches. <span>?</span> for help.</div>`;
        return;
      }
      paletteResults.innerHTML = matches.map((c, i) =>
        `<div class="palette-row" data-idx="${i}" data-key="${c.key}">
          <span>${c.key}</span>
          <span class="palette-row-desc">${c.desc}</span>
        </div>`
      ).join('');
      paletteResults.querySelectorAll('.palette-row').forEach(row => {
        row.addEventListener('click', () => {
          const cmd = COMMANDS.find(c => c.key === (row as HTMLElement).dataset.key);
          closePalette();
          cmd?.run();
        });
      });
    }

    function openPalette() {
      paletteOverlay.hidden = false;
      paletteInput.value = '';
      renderPalette('');
      paletteInput.focus();
    }

    function closePalette() {
      paletteOverlay.hidden = true;
    }

    paletteInput?.addEventListener('input', () => renderPalette(paletteInput.value.trim()));

    paletteInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = paletteInput.value.trim().toLowerCase();
        const cmd = COMMANDS.find(c => c.key === q || c.key.includes(q));
        closePalette();
        cmd?.run();
      }
    });

    paletteOverlay?.addEventListener('click', (e) => {
      if (e.target === paletteOverlay) closePalette();
    });

    // ── Help HUD ──────────────────────────────────────────────────────
    const helpOverlay = document.getElementById('help-overlay') as HTMLElement;

    function openHelp() { helpOverlay.hidden = false; }
    function closeHelp() { helpOverlay.hidden = true; }

    helpOverlay?.addEventListener('click', (e) => {
      if (e.target === helpOverlay) closeHelp();
    });

    // ── Global keyboard router ────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      const t = e.target as HTMLElement;
      const inInput = t.tagName === 'INPUT' || t.tagName === 'TEXTAREA';

      if (e.key === 'Escape') {
        closePalette();
        closeHelp();
        return;
      }

      if (inInput) return;

      if (e.key === '/' || e.key === ':') {
        e.preventDefault();
        openPalette();
        return;
      }

      if (e.key === '?') {
        e.preventDefault();
        helpOverlay.hidden ? openHelp() : closeHelp();
        return;
      }

      if (e.key === 'g') {
        const handler = (e2: KeyboardEvent) => {
          document.removeEventListener('keydown', handler);
          if (e2.key === 'r') document.getElementById('research')?.scrollIntoView({ behavior: 'smooth' });
          if (e2.key === 'f') document.getElementById('flagship')?.scrollIntoView({ behavior: 'smooth' });
          if (e2.key === 't') window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        document.addEventListener('keydown', handler, { once: true });
        return;
      }
    });

    // ── Scroll reveal (used by about.astro) ───────────────────────────
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const els = document.querySelectorAll('.reveal, .reveal-left');
      if (!els.length) return;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      els.forEach((el) => observer.observe(el));
    })();

    // ── Expose globals for cross-script use ───────────────────────────
    (window as any).__sq = { setTheme, openPalette };
  </script>
</body>
</html>

<style>
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 28px;
    border-bottom: 1px solid var(--color-line);
    position: sticky;
    top: 2px; /* sit below the 2px hairline */
    z-index: 50;
    background: var(--color-bg);
    font-family: var(--font-mono);
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    flex-wrap: wrap;
  }

  .topbar-left strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .divider {
    color: var(--color-line);
    user-select: none;
  }

  .online {
    color: var(--color-ok);
  }

  .mute {
    color: var(--color-mute);
  }

  .topbar-nav {
    display: flex;
    gap: 20px;
  }

  .topbar-link {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--color-mute);
    transition: color 0.1s;
  }

  .topbar-link:hover {
    color: var(--color-text);
  }

  .topbar-link--active {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 1px;
  }

  .site-footer {
    margin-top: 32px;
    border-top: 1px solid var(--color-line);
    padding: 36px 28px 28px;
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
  }

  @media (max-width: 640px) {
    .topbar-nav { display: none; }
    .topbar-left { gap: 8px; }
    #uptime-val, #scroll-pct, #last-key-chip { display: none; }
    /* hide the dividers around hidden elements */
    .topbar-left .divider:nth-child(n+4) { display: none; }
  }
</style>
