---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Robotics & Automation Engineer — ROS2, MPPI, Computer Vision, Embedded Systems',
  ogImage = '/og-default.png',
} = Astro.props;

const currentPath = Astro.url.pathname;

const navLinkBase = 'text-sm font-medium transition-colors';
const navActive   = 'text-zinc-900 dark:text-zinc-100 underline decoration-[--color-accent] decoration-2 underline-offset-4';
const navInactive = 'text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100';

function navClass(href: string): string {
  const active = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
  return `${navLinkBase} ${active ? navActive : navInactive}`;
}

const siteTitle = title === 'Muhammad Suleiman Qureshi'
  ? title
  : `${title} — Muhammad Suleiman Qureshi`;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="Muhammad Suleiman Qureshi" />

  <!-- OG -->
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />

  <title>{siteTitle}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Preconnect for Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />


  <!-- Dark mode init: prevent flash -->
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-[--color-bg] dark:bg-[--color-bg-dark] text-[--color-text] dark:text-[--color-text-dark] min-h-screen">
  <nav id="main-nav" class="fixed top-4 left-4 right-4 z-50 flex items-center justify-between px-5 py-3 rounded-2xl bg-white/80 dark:bg-zinc-900/80 backdrop-blur border border-zinc-200 dark:border-zinc-800 shadow-sm transition-shadow duration-200">
    <a href="/" class="font-heading text-lg font-semibold tracking-tight hover:text-[--color-accent] transition-colors">
      Suleiman
    </a>
    <div class="flex items-center gap-6">
      <a href="/research" class={navClass('/research')}>Research</a>
      <a href="/projects" class={navClass('/projects')}>Projects</a>
      <a href="/about"    class={navClass('/about')}>About</a>
      <a href="/contact"  class={navClass('/contact')}>Contact</a>
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="cursor-pointer p-1.5 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" class="hidden dark:block w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" class="block dark:hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>

  <main class="pt-24">
    <slot />
  </main>

  <footer class="mt-24 border-t border-zinc-200 dark:border-zinc-800 py-8 px-6 text-center text-sm text-zinc-500 dark:text-zinc-500">
    <p>Muhammad Suleiman Qureshi · Karachi, Pakistan</p>
    <div class="flex justify-center gap-5 mt-3">
      <a href="https://www.linkedin.com/in/msuleimanqureshi" target="_blank" rel="noopener" class="hover:text-[--color-accent] transition-colors" aria-label="LinkedIn">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="mailto:mohammadsulaiman500@gmail.com" class="hover:text-[--color-accent] transition-colors" aria-label="Email">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
    </div>
    <p class="mt-4 text-xs text-zinc-400">Built with Astro · <a href="/Suleiman_Resume_April_2026.pdf" class="hover:text-[--color-accent]">Download Resume</a></p>
  </footer>

  <script>
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Nav shadow on scroll
    (function () {
      const nav = document.getElementById('main-nav');
      if (!nav) return;
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            nav.classList.toggle('nav-scrolled', window.scrollY > 20);
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    })();

    // Scroll-reveal
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const els = document.querySelectorAll('.reveal, .reveal-left');
      if (!els.length) return;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      els.forEach((el) => observer.observe(el));
    })();
  </script>
</body>
</html>

<style>
  nav { font-family: var(--font-body); }
  .font-heading { font-family: var(--font-heading); }
</style>
