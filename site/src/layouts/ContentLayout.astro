---
import BaseLayout from './BaseLayout.astro';
import StatusBadge from '../components/StatusBadge.astro';

export interface Props {
  title: string;
  status: string;
  date: string;
  tags: string[];
  description?: string;
  backHref: string;
  backLabel: string;
  cover?: string;
}

const { title, status, date, tags, description, backHref, backLabel, cover } = Astro.props;
---
<BaseLayout title={title} description={description ?? title}>
  <article class="content-wrap">
    <!-- Back link -->
    <a href={backHref} class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      {backLabel}
    </a>

    <!-- Cover image -->
    {cover && (
      <div class="cover-wrap">
        <img src={`/media/${cover}`} alt={title} class="cover-img" />
      </div>
    )}

    <!-- Header -->
    <header class="content-header">
      <div class="header-meta">
        <StatusBadge status={status} />
        <span class="header-date">{date}</span>
      </div>
      <h1 class="content-title">{title}</h1>
      <div class="header-tags">
        {tags.map((tag) => <span class="tag-pill">{tag}</span>)}
      </div>
    </header>

    <!-- Body -->
    <div class="prose dark:prose-invert max-w-none
      prose-h1:hidden
      prose-a:text-[--color-accent] prose-a:no-underline hover:prose-a:underline
      prose-code:text-sm prose-code:bg-[--color-panel] prose-code:px-1 prose-code:py-0.5
      prose-pre:bg-[--color-panel]
      prose-table:text-sm
      prose-blockquote:border-l-[--color-line] prose-blockquote:not-italic
    ">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 28px 60px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    text-decoration: none;
    margin-bottom: 28px;
    letter-spacing: 0.04em;
    transition: color 0.1s;
  }
  .back-link:hover { color: var(--color-text); }

  .cover-wrap {
    margin-bottom: 28px;
    overflow: hidden;
    border: 1px solid var(--color-line);
  }
  .cover-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .content-header {
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-line);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .header-date {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-mute);
  }

  .content-title {
    font-size: 24px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0 0 14px;
  }

  .header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  @media (max-width: 640px) {
    .content-wrap { padding: 20px 16px 40px; }
    .content-title { font-size: 18px; }
  }
</style>
