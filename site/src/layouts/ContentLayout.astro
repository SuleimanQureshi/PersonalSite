---
import BaseLayout from './BaseLayout.astro';
import StatusBadge from '../components/StatusBadge.astro';

export interface Props {
  title: string;
  status: string;
  date: string;
  tags: string[];
  description?: string;
  backHref: string;
  backLabel: string;
  cover?: string;
}

const { title, status, date, tags, description, backHref, backLabel, cover } = Astro.props;
---
<BaseLayout title={title} description={description ?? title}>
  <article class="max-w-3xl mx-auto px-6 py-10">
    <!-- Back link -->
    <a
      href={backHref}
      class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors mb-8 cursor-pointer"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      {backLabel}
    </a>

    <!-- Cover image (shown only if provided) -->
    {cover && (
      <div class="rounded-2xl overflow-hidden mb-8 aspect-video bg-zinc-100 dark:bg-zinc-800">
        <img src={`/media/${cover}`} alt={title} class="w-full h-full object-cover" />
      </div>
    )}

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <StatusBadge status={status} />
        <span class="text-sm text-zinc-400 dark:text-zinc-500">{date}</span>
      </div>
      <h1 class="font-heading text-4xl font-semibold leading-tight text-zinc-900 dark:text-zinc-100 mb-4">
        {title}
      </h1>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => <span class="tag-pill">{tag}</span>)}
      </div>
    </header>

    <!-- Content -->
    <div class="prose dark:prose-invert max-w-none
      prose-headings:font-heading
      prose-h1:hidden
      prose-a:text-[--color-accent] prose-a:no-underline hover:prose-a:underline
      prose-code:text-sm prose-code:bg-zinc-100 dark:prose-code:bg-zinc-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-zinc-900 dark:prose-pre:bg-zinc-950
      prose-table:text-sm
      prose-img:rounded-xl prose-img:shadow-md
      prose-blockquote:border-l-[--color-accent] prose-blockquote:not-italic prose-blockquote:font-heading
    ">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .font-heading { font-family: var(--font-heading); }
</style>
