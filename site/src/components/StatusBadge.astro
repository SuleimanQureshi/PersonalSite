---
export interface Props {
  status: string;
}
const { status } = Astro.props;

const labels: Record<string, string> = {
  published: 'Published',
  completed: 'Completed',
  preprint: 'Preprint',
  'in-progress': 'In Progress',
  archived: 'Archived',
};

const label = labels[status] ?? status;
---
<span class={`status-badge status-${status}`}><span aria-hidden="true">●</span> {label}</span>
