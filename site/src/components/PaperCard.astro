---
import StatusBadge from './StatusBadge.astro';

export interface Props {
  title: string;
  slug: string;
  status: string;
  date: string;
  tags: string[];
  summary?: string;
  cover?: string;
  venue?: string;
}

const { title, slug, status, date, tags, summary, venue } = Astro.props;
const href = `/research/${slug}`;
---
<a href={href} class="paper-card">
  <div class="card-header">
    <StatusBadge status={status} />
    <span class="card-date">{date}</span>
  </div>
  <h3 class="card-title">{title}</h3>
  {venue && <p class="card-venue">{venue}</p>}
  {summary && <p class="card-summary">{summary}</p>}
  <div class="card-tags">
    {tags.slice(0, 4).map((tag) => (
      <span class="tag-pill">{tag}</span>
    ))}
  </div>
</a>

<style>
  .paper-card {
    display: block;
    border: 1px solid var(--color-line);
    background: var(--color-panel);
    padding: 16px;
    text-decoration: none;
    transition: border-color 0.1s;
    height: 100%;
  }
  .paper-card:hover { border-color: var(--color-blue); }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
  }

  .card-date {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 13px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 6px;
  }
  .paper-card:hover .card-title { color: var(--color-blue); }

  .card-venue {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    margin: 0 0 8px;
  }

  .card-summary {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-mute);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    margin: 0 0 10px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 10px;
  }
</style>
