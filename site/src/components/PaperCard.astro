---
import StatusBadge from './StatusBadge.astro';

export interface Props {
  title: string;
  slug: string;
  status: string;
  date: string;
  tags: string[];
  summary?: string;
  cover?: string;
  venue?: string;
}

const { title, slug, status, date, tags, summary, cover, venue } = Astro.props;
const href = `/research/${slug}`;
---
<a
  href={href}
  class="group block rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 hover:border-zinc-300 dark:hover:border-zinc-700 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 cursor-pointer overflow-hidden"
>
  {cover ? (
    <div class="aspect-video overflow-hidden bg-zinc-100 dark:bg-zinc-800">
      <img
        src={`/media/${cover}`}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-video shimmer-bg flex items-center justify-center">
      <!-- Paper icon -->
      <svg class="w-10 h-10 text-zinc-300 dark:text-zinc-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
    </div>
  )}
  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <StatusBadge status={status} />
      <span class="text-xs text-zinc-400 dark:text-zinc-500 shrink-0">{date}</span>
    </div>
    <h3 class="font-heading text-lg font-semibold leading-snug text-zinc-900 dark:text-zinc-100 group-hover:text-[--color-accent] transition-colors mb-1">
      {title}
    </h3>
    {venue && <p class="text-xs text-zinc-500 dark:text-zinc-400 mb-2 font-medium">{venue}</p>}
    {summary && (
      <p class="text-sm text-zinc-600 dark:text-zinc-400 line-clamp-3 leading-relaxed">{summary}</p>
    )}
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.slice(0, 4).map((tag) => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>
  </div>
</a>

<style>
  .font-heading { font-family: var(--font-heading); }
</style>
